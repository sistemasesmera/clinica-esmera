---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageHero from '../../components/PageHero.astro';
import PageCTA from '../../components/PageCTA.astro';
import Footer from '../../components/Footer.astro';

const data: Record<string, any> = {
  faciales: {
    title: "Medicina Estética Facial",
    eyebrow: "Médico Estético · Faciales",
    description: "Tratamientos médicos avanzados para el rostro supervisados por especialistas. Protocolos personalizados para un rejuvenecimiento natural y resultados que perduran.",
    intro: "La medicina estética facial ofrece posibilidades que van más allá de la cosmética convencional. Con técnicas mínimamente invasivas y productos de calidad médica, conseguimos resultados que respetan la expresión natural y la identidad de cada paciente.",
    tratamientos: [
      { n: "Toxina Botulínica",   d: "Relajación muscular selectiva para tratar arrugas de expresión (frente, entrecejo, patas de gallo). Resultado natural, sin congelar la expresión. Efecto de 4 a 6 meses.", dur: "30 min" },
      { n: "Ácido Hialurónico",  d: "Relleno y volumización con ácido hialurónico de reticulación variable según la zona. Labios, ojeras, pómulos, surcos nasogenianos. Resultado inmediato y natural.", dur: "45 min" },
      { n: "Bioestimuladores",   d: "Estimulación profunda de la producción de colágeno con PLLA o hidroxiapatita cálcica. Regeneración progresiva y duradera de la arquitectura dérmica.", dur: "60 min" },
      { n: "Mesoterapia Facial", d: "Microinyecciones de cócteles vitamínicos, ácido hialurónico no reticulado y aminoácidos. Hidratación profunda, luminosidad y mejora de la calidad de la piel.", dur: "45 min" },
      { n: "PRP Facial",        d: "Plasma rico en plaquetas autólogo. Regeneración celular con los factores de crecimiento propios del paciente. Ideal para calidad de piel y pérdida de cabello.", dur: "60 min" },
      { n: "Peelings Médicos",  d: "TCA, fenol o combinaciones de ácidos a concentraciones médicas para tratar manchas, cicatrices y fotoenvejecimiento con mayor profundidad y eficacia.", dur: "45 min" },
    ],
    proceso: [
      { p: "01", t: "Valoración médica", d: "Consulta con nuestro médico estético para analizar tu estado, objetivos y contraindicaciones." },
      { p: "02", t: "Diseño del protocolo", d: "Diseñamos el tratamiento personalizado, producto a utilizar, dosis y zonas de actuación." },
      { p: "03", t: "Procedimiento", d: "Realizamos el tratamiento con máxima precisión y los más altos estándares de seguridad." },
      { p: "04", t: "Control y seguimiento", d: "Revisión a las 2-4 semanas para evaluar el resultado y ajustar si es necesario." },
    ],
  },
  corporales: {
    title: "Medicina Estética Corporal",
    eyebrow: "Médico Estético · Corporales",
    description: "Procedimientos médico-estéticos para el cuerpo que combinan diagnóstico clínico y tecnología de vanguardia para remodelar tu figura de forma segura y eficaz.",
    intro: "La medicina estética corporal ofrece soluciones reales para las zonas del cuerpo que no responden al ejercicio ni a la dieta. Con técnicas mínimamente invasivas, conseguimos resultados equivalentes a procedimientos quirúrgicos sin los riesgos ni el tiempo de recuperación.",
    tratamientos: [
      { n: "Mesoterapia Corporal",        d: "Microinyecciones de lipolíticos, drenantes y reafirmantes directamente en la zona a tratar. Reducción de grasa localizada y celulitis desde la primera sesión.", dur: "45 min" },
      { n: "Carboxiterapia",             d: "Infiltración de CO₂ medicinal para mejorar la microcirculación, oxigenar el tejido y reducir la grasa y la celulitis. Sin efectos secundarios.", dur: "45 min" },
      { n: "Lipolíticos Inyectables",    d: "Tratamiento con desoxicolato sódico o fosfatidilcolina para la eliminación selectiva de grasa localizada. Alternativa segura a la liposucción.", dur: "45 min" },
      { n: "PRP Corporal",              d: "Plasma rico en plaquetas para regeneración tisular, mejora de cicatrices, estrías y calidad de la piel corporal.", dur: "60 min" },
      { n: "Vitaminas IV Premium",       d: "Sueroterapia con combinaciones de vitaminas, minerales y antioxidantes adaptadas a tu objetivo: energía, detox, inmunidad o belleza.", dur: "60 min" },
      { n: "Bioestimuladores Corporales", d: "Estimulación del colágeno en zonas de flacidez corporal. Muslos internos, brazos, escote y glúteos. Firmeza duradera sin cirugía.", dur: "60 min" },
    ],
    proceso: [
      { p: "01", t: "Diagnóstico corporal", d: "Evaluación médica de la zona, tipo de tejido, objetivos y contraindicaciones del paciente." },
      { p: "02", t: "Protocolo médico", d: "El médico diseña el tratamiento específico: producto, dosis, número de sesiones y pauta." },
      { p: "03", t: "Tratamiento", d: "Sesión con los más altos estándares médicos de seguridad e higiene." },
      { p: "04", t: "Seguimiento", d: "Revisión periódica para evaluar la evolución y ajustar el protocolo si es necesario." },
    ],
  },
};

export function getStaticPaths() {
  return ["faciales","corporales"].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const d = data[slug];
---

<Layout title={`${d.title} · Medicina Estética · Clínica Esmera`}>
  <Navbar />
  <PageHero
    eyebrow={d.eyebrow}
    title={d.title}
    description={d.description}
    breadcrumb={[
      { label: "Médico Estético", href: "/medico-estetico/" },
      { label: d.title, href: `/medico-estetico/${slug}` }
    ]}
  />

  <section class="me-trat">
    <div class="container">
      <p class="met-intro">{d.intro}</p>

      <div class="eyebrow"><span>Tratamientos médicos</span></div>
      <h2 class="sec-title" style="margin-bottom:36px">Qué <em>ofrecemos</em></h2>

      <div class="met-list">
        {d.tratamientos.map((t: any, i: number) => (
          <div class="met-row">
            <div class="metr-num">{String(i+1).padStart(2,'0')}</div>
            <div class="metr-body">
              <div class="metr-top">
                <h3 class="metr-name">{t.n}</h3>
                <span class="metr-dur">{t.dur}</span>
              </div>
              <p class="metr-desc">{t.d}</p>
            </div>
            <a href="/nosotros#contacto" class="metr-cta">
              Consultar
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 5.5h7M6 2.5l2.5 3L6 8.5"/></svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Proceso -->
      <div class="met-proceso">
        <div class="eyebrow"><span>Protocolo médico</span></div>
        <h2 class="sec-title" style="margin-bottom:40px">El <em>proceso</em></h2>
        <div class="mp-grid">
          {d.proceso.map((p: any) => (
            <div class="mp-step">
              <div class="mps-n">{p.p}</div>
              <div class="mps-l"></div>
              <h3 class="mps-t">{p.t}</h3>
              <p class="mps-d">{p.d}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="met-aviso">
        <span>✦</span>
        <p>Todos nuestros tratamientos médicos incluyen valoración previa gratuita con nuestro equipo especializado. Tu seguridad es nuestra prioridad absoluta.</p>
      </div>
    </div>
  </section>

  <PageCTA heading="Solicita tu valoración médica gratuita" sub="Sin compromiso. Nuestro médico estético analizará tu caso y diseñará el protocolo más seguro y eficaz para ti." />
  <Footer />
</Layout>

<style>
  .me-trat { padding: 96px 0; background: var(--ivory); }
  .met-intro { font-size: 1rem; color: var(--text-muted); line-height: 1.82; font-weight: 300; max-width: 680px; margin-bottom: 72px; }

  .met-list { border-top: 1px solid rgba(0,0,0,0.07); margin-bottom: 96px; }
  .met-row {
    display: grid; grid-template-columns: 48px 1fr 100px;
    gap: 28px; align-items: start;
    padding: 28px 16px; margin: 0 -16px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: background var(--t);
  }
  .met-row:hover { background: var(--ivory-mid); }

  .metr-num { font-family: var(--font-display); font-style: italic; font-weight: 300; font-size: 0.75rem; color: var(--gold); opacity: 0.7; padding-top: 4px; }
  .metr-top { display: flex; align-items: baseline; gap: 14px; margin-bottom: 8px; flex-wrap: wrap; }
  .metr-name { font-family: var(--font-display); font-size: 1.2rem; font-weight: 400; color: var(--dark); }
  .metr-dur { font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.1em; font-weight: 300; }
  .metr-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; font-weight: 300; }
  .metr-cta {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--dark); border-bottom: 1px solid rgba(213,192,57,0.4);
    padding-bottom: 2px; padding-top: 4px; transition: all 0.2s; width: fit-content;
  }
  .metr-cta:hover { color: var(--gold-warm); gap: 9px; }

  .met-proceso { margin-bottom: 56px; }
  .mp-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 32px; }
  .mps-n { font-family: var(--font-display); font-style: italic; font-size: 2rem; font-weight: 300; color: var(--gold); opacity: 0.6; line-height: 1; margin-bottom: 12px; }
  .mps-l { width: 24px; height: 1px; background: var(--gold); opacity: 0.3; margin-bottom: 14px; }
  .mps-t { font-family: var(--font-display); font-size: 1.05rem; font-weight: 400; color: var(--dark); margin-bottom: 8px; }
  .mps-d { font-size: 0.82rem; color: var(--text-muted); line-height: 1.65; font-weight: 300; }

  .met-aviso {
    display: flex; gap: 14px; align-items: flex-start;
    background: var(--ivory-mid); border: 1px solid rgba(213,192,57,0.18);
    padding: 18px 22px; border-radius: var(--radius);
  }
  .met-aviso span { color: var(--gold); opacity: 0.5; flex-shrink: 0; margin-top: 1px; }
  .met-aviso p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; font-weight: 300; }

  @media (max-width: 860px) {
    .met-row { grid-template-columns: 40px 1fr; }
    .metr-cta { grid-column: 2; }
    .mp-grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 520px) {
    .met-row { grid-template-columns: 1fr; }
    .metr-num { display: none; }
    .mp-grid { grid-template-columns: 1fr; }
    .me-trat { padding: 72px 0; }
  }
</style>
