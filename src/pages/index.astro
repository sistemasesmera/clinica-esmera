---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    num: "01", href: "/estetico/",
    title: "Estética",
    desc: "Faciales, corporales, micropigmentación y masajes que cuidan y realzan tu belleza natural con técnicas de alta eficacia.",
    items: ["Faciales", "Corporales", "Micropigmentación", "Masajes"],
  },
  {
    num: "02", href: "/medico-estetico/",
    title: "Medicina Estética",
    desc: "Tratamientos médicos avanzados supervisados por especialistas. Resultados visibles, duraderos y con máxima seguridad.",
    items: ["Toxina Botulínica", "Ácido Hialurónico", "Mesoterapia", "Bioestimuladores"],
  },
  {
    num: "03", href: "/aparatologia/",
    title: "Aparatología",
    desc: "Tecnología certificada de grado médico: desde HIFU hasta criolipólisis. Los tratamientos más eficaces del mercado.",
    items: ["HIFU Ultrafocal", "Radiofrecuencia", "Criolipólisis", "Presoterapia"],
  },
  {
    num: "04", href: "/bonos",
    title: "Bonos & Packs",
    desc: "Packs de sesiones diseñados para maximizar resultados y ahorro. Desde 3 hasta 10 sesiones a medida.",
    items: ["Bono Esencial · 3 sesiones", "Bono Intensivo · 6 sesiones", "Bono VIP · 10 sesiones"],
  },
];

const valores = [
  {
    t: "Resultados reales",
    d: "Sin promesas vacías. Medimos nuestro éxito por las transformaciones verificables de cada cliente.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  },
  {
    t: "Tecnología certificada",
    d: "Equipos de grado médico con marcado CE y eficacia avalada por estudios clínicos internacionales.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    t: "Equipo especializado",
    d: "Médicos estéticos y esteticistas tituladas en formación continua con las últimas técnicas del sector.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    t: "Trato personalizado",
    d: "Protocolos exclusivos adaptados a tus objetivos, tu piel y tu estilo de vida. Cada persona es única.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];

const reviews = [
  { ini: "M", name: "María L.", text: "Llevo tres meses con el protocolo de medicina estética y los resultados son increíbles. El equipo es muy profesional y el trato, excelente.", trat: "Medicina Estética Facial" },
  { ini: "C", name: "Carlos M.", text: "Vine por la criolipólisis con dudas y salí encantado. Los resultados empezaron a verse desde el primer mes.", trat: "Criolipólisis" },
  { ini: "A", name: "Ana P.", text: "La micropigmentación de cejas me cambió la cara. Quedaron naturalísimas. El proceso fue cómodo y el resultado, exactamente lo que buscaba.", trat: "Micropigmentación" },
];
---

<Layout>
  <Navbar />
  <Hero />
  <Stats />

  <!-- Valoración gratuita -->
  <section class="home-val">
    <div class="container hval-inner">

      <div class="hval-badge">
        <span class="hval-dot"></span>
        Disponible ahora · Sin lista de espera
      </div>

      <h2 class="hval-title">
        Tu primera valoración médica,<br /><em>completamente gratuita</em>
      </h2>

      <p class="hval-lead">
        Un especialista analiza tu piel, estudia tus objetivos y te diseña un protocolo personalizado.<br class="hval-br" />
        Sin pagar nada. Sin ningún tipo de obligación.
      </p>

      <div class="hval-actions">
        <a href="/nosotros#contacto" class="btn btn-gold">Reservar mi valoración</a>
        <a
          href="https://wa.me/34661310256?text=Hola%2C%20me%20gustar%C3%ADa%20reservar%20mi%20valoraci%C3%B3n%20m%C3%A9dica%20gratuita"
          class="btn btn-ghost-dark"
          target="_blank" rel="noopener"
        >
          Consultar por WhatsApp
        </a>
      </div>

      <ul class="hval-trust">
        <li><span class="hval-check">✓</span> Sin coste</li>
        <li><span class="hval-check">✓</span> Sin obligación de compra</li>
        <li><span class="hval-check">✓</span> Especialista médico</li>
        <li><span class="hval-check">✓</span> Protocolo 100% personalizado</li>
      </ul>

    </div>
  </section>

  <!-- Nuestros tratamientos -->
  <section class="home-services">
    <div class="container">
      <div class="hs-hd">
        <div class="eyebrow"><span>Nuestros tratamientos</span></div>
        <h2 class="sec-title">Todo lo que necesitas<br /><em>en un solo lugar</em></h2>
        <p class="sec-lead">Estética, medicina estética y aparatología de primer nivel, con un equipo de profesionales especializados.</p>
      </div>
      <div class="hs-grid">
        {categories.map(c => (
          <a href={c.href} class="hs-card">
            <div class="hs-num">{c.num}</div>
            <div class="hs-rule"></div>
            <h3 class="hs-title">{c.title}</h3>
            <p class="hs-desc">{c.desc}</p>
            <ul class="hs-list">
              {c.items.map(i => <li><span>—</span>{i}</li>)}
            </ul>
            <span class="hs-cta">
              Ver tratamientos
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué elegirnos -->
  <section class="home-why">
    <div class="container hw-grid">
      <div class="hw-left">
        <div class="eyebrow"><span>Por qué elegirnos</span></div>
        <h2 class="sec-title">Más de una década<br /><em>a tu lado</em></h2>
        <p class="sec-lead">Clínica Esmera nació en 2014 con una misión: hacer accesible la estética y medicina estética de primera calidad. Hoy somos referente en Madrid, con un equipo dedicado a los resultados reales.</p>
        <a href="/nosotros" class="btn btn-ghost-dark hw-btn">Conoce nuestra historia</a>
      </div>
      <div class="hw-right">
        {valores.map(v => (
          <div class="hw-valor">
            <div class="hwv-icon" set:html={v.svg}></div>
            <div>
              <p class="hwv-t">{v.t}</p>
              <p class="hwv-d">{v.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reseñas -->
  <section class="home-reviews">
    <div class="container">
      <div class="hr-hd">
        <div>
          <div class="eyebrow"><span>Reseñas</span></div>
          <h2 class="sec-title">Lo que dicen<br /><em>nuestros clientes</em></h2>
        </div>
        <div class="hr-rating">
          <span class="hr-stars">★★★★★</span>
          <span>4.9 de 5 · +500 reseñas</span>
        </div>
      </div>
      <div class="hr-grid">
        {reviews.map(r => (
          <div class="hr-card">
            <p class="hrc-stars">★★★★★</p>
            <p class="hrc-text">"{r.text}"</p>
            <div class="hrc-foot">
              <div class="hrc-av">{r.ini}</div>
              <div>
                <p class="hrc-name">{r.name}</p>
                <p class="hrc-trat">{r.trat}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Oferta banner -->
  <section class="home-banner">
    <div class="container hb-inner">
      <div>
        <p class="hb-tag">Oferta de bienvenida</p>
        <h2 class="hb-h">Primera consulta gratuita<br />+ <em>40% en tu primer tratamiento</em></h2>
      </div>
      <a href="/nosotros#contacto" class="btn btn-gold hb-btn">Reservar ahora</a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="home-newsletter">
    <div class="container hn-inner">

      <div class="hn-text">
        <div class="eyebrow"><span>Newsletter</span></div>
        <h2 class="hn-title">Consejos, ofertas<br /><em>y novedades</em></h2>
        <p class="hn-lead">Sé la primera en conocer nuestras promociones exclusivas, nuevos tratamientos y consejos de nuestros especialistas. Sin spam.</p>
      </div>

      <div class="hn-right">
        <form class="hn-form" id="newsletterForm" novalidate>
          <div class="hn-row">
            <input
              type="email"
              id="newsletterEmail"
              class="hn-input"
              placeholder="Tu correo electrónico"
              autocomplete="email"
              required
            />
            <button type="submit" class="btn btn-gold hn-btn">Suscribirme</button>
          </div>
          <p class="hn-error-msg" id="newsletterError">Introduce un email válido.</p>
          <p class="hn-privacy">Sin spam · Cancela cuando quieras · Solo contenido de valor</p>
        </form>

        <div class="hn-success" id="newsletterSuccess">
          <div class="hn-success-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <p class="hn-success-title">¡Ya eres parte de la comunidad!</p>
          <p class="hn-success-sub">Pronto recibirás nuestras novedades en tu bandeja de entrada.</p>
        </div>
      </div>

    </div>
  </section>

  <Footer />
<script>
  const form    = document.getElementById('newsletterForm')    as HTMLFormElement | null;
  const input   = document.getElementById('newsletterEmail')   as HTMLInputElement | null;
  const errorEl = document.getElementById('newsletterError')   as HTMLElement | null;
  const success = document.getElementById('newsletterSuccess') as HTMLElement | null;

  const isValidEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

  input?.addEventListener('input', () => {
    input.classList.remove('is-error');
    errorEl?.classList.remove('is-visible');
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = input?.value.trim() ?? '';

    if (!isValidEmail(email)) {
      input?.classList.add('is-error');
      errorEl?.classList.add('is-visible');
      input?.focus();
      return;
    }

    form.style.display = 'none';
    success?.classList.add('is-visible');
  });
</script>

</Layout>

<style>
  /* ── Home Services ── */
  .home-services { padding: 120px 0; background: var(--ivory); }
  .hs-hd { margin-bottom: 64px; }

  .hs-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 1px; background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.06); border-radius: var(--radius);
    overflow: hidden;
  }

  .hs-card {
    background: var(--white); padding: 36px 28px 32px;
    display: flex; flex-direction: column;
    transition: background var(--t); cursor: pointer;
    text-decoration: none;
  }
  .hs-card:hover { background: var(--ivory-mid); }

  .hs-num { font-family: var(--font-display); font-style: italic; font-weight: 200; font-size: 2.4rem; color: var(--dark); letter-spacing: -0.02em; margin-bottom: 14px; opacity: 0.25; line-height: 1; }
  .hs-rule { width: 24px; height: 1px; background: var(--dark); opacity: 0.15; margin-bottom: 18px; }
  .hs-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 600; color: var(--dark); margin-bottom: 12px; letter-spacing: -0.01em; }
  .hs-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.72; margin-bottom: 20px; font-weight: 300; flex: 1; }
  .hs-list { list-style: none; margin-bottom: 24px; display: flex; flex-direction: column; gap: 6px; }
  .hs-list li { display: flex; align-items: center; gap: 8px; font-size: 0.78rem; color: var(--text-soft); font-weight: 400; }
  .hs-list li span { color: var(--stone-light); }

  .hs-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--dark);
    border-bottom: 1px solid rgba(213,192,57,0.4);
    padding-bottom: 2px; width: fit-content;
    transition: all 0.25s; margin-top: auto;
  }
  .hs-card:hover .hs-cta { color: var(--gold-warm); border-color: var(--gold); gap: 10px; }

  /* ── Why ── */
  .home-why { padding: 120px 0; background: var(--ivory-mid); }
  .hw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .hw-btn { margin-top: 36px; }
  .hw-right { display: flex; flex-direction: column; gap: 24px; padding-top: 8px; }
  .hw-valor { display: flex; gap: 16px; align-items: flex-start; }
  .hwv-icon {
    width: 42px; height: 42px; flex-shrink: 0;
    background: rgba(197,180,50,0.10);
    border: 1px solid rgba(197,180,50,0.22);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-warm);
    transition: background 0.25s, border-color 0.25s;
  }
  .hw-valor:hover .hwv-icon {
    background: rgba(197,180,50,0.18);
    border-color: rgba(197,180,50,0.45);
  }
  .hwv-t { font-size: 0.88rem; font-weight: 700; color: var(--dark); margin-bottom: 5px; letter-spacing: 0.02em; }
  .hwv-d { font-size: 0.82rem; color: var(--text-muted); line-height: 1.65; font-weight: 300; }

  /* ── Reviews ── */
  .home-reviews { padding: 96px 0; background: var(--ivory); }
  .hr-hd { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 48px; flex-wrap: wrap; gap: 16px; }
  .hr-rating { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--text-muted); font-weight: 300; padding-bottom: 4px; }
  .hr-stars { color: var(--gold); font-size: 1rem; letter-spacing: 2px; }
  .hr-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .hr-card { background: var(--white); padding: 28px 24px; border: 1px solid rgba(0,0,0,0.05); border-radius: var(--radius); transition: box-shadow var(--t); }
  .hr-card:hover { box-shadow: var(--shadow-soft); }
  .hrc-stars { color: var(--gold); font-size: 0.85rem; letter-spacing: 2px; margin-bottom: 14px; }
  .hrc-text { font-size: 0.85rem; color: var(--text-muted); line-height: 1.75; margin-bottom: 20px; font-style: italic; font-weight: 300; }
  .hrc-foot { display: flex; align-items: center; gap: 12px; }
  .hrc-av { width: 34px; height: 34px; border-radius: 50%; background: var(--dark); color: var(--ivory); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
  .hrc-name { font-weight: 600; font-size: 0.82rem; color: var(--dark); }
  .hrc-trat { font-size: 0.72rem; color: var(--text-muted); font-weight: 300; }

  /* ── Banner ── */
  .home-banner { background: var(--dark); padding: 72px 0; }
  .hb-inner { display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .hb-tag { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(213,192,57,0.6); margin-bottom: 10px; font-weight: 400; }
  .hb-h { font-family: var(--font-display); font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 200; color: rgba(255,255,255,0.9); line-height: 1.25; letter-spacing: -0.02em; }
  .hb-h em { font-style: italic; color: var(--gold); font-weight: 600; }
  .hb-btn { flex-shrink: 0; }

  /* ── Valoración gratuita ── */
  .home-val {
    background: var(--ivory-deep);
    padding: 96px 0;
    position: relative;
    text-align: center;
  }
  .home-val::before {
    content: '';
    position: absolute; top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197,180,50,0.4), transparent);
  }
  .home-val::after {
    content: '';
    position: absolute; bottom: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197,180,50,0.4), transparent);
  }

  .hval-inner { display: flex; flex-direction: column; align-items: center; }

  .hval-badge {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); font-weight: 400;
    margin-bottom: 28px;
  }
  .hval-dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 50%;
    background: var(--gold-warm);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.75); }
  }

  .hval-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    color: var(--dark);
    line-height: 1.22;
    margin-bottom: 24px;
  }
  .hval-title em { font-style: italic; color: var(--dark); font-weight: 500; }

  .hval-lead {
    font-size: 1rem; color: var(--text-soft); line-height: 1.8;
    font-weight: 300; max-width: 560px; margin-bottom: 40px;
  }
  .hval-br { display: block; }

  .hval-actions {
    display: flex; gap: 14px; flex-wrap: wrap;
    justify-content: center; margin-bottom: 36px;
  }

  .hval-trust {
    list-style: none;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 20px 36px;
  }
  .hval-trust li {
    display: flex; align-items: center; gap: 7px;
    font-size: 0.78rem; color: var(--text-muted); font-weight: 400;
    letter-spacing: 0.02em;
  }
  .hval-check { color: var(--dark); font-weight: 600; }

  /* Responsive */
  @media (max-width: 1024px) { .hs-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 860px) {
    .hw-grid { grid-template-columns: 1fr; gap: 48px; }
    .hr-grid { grid-template-columns: 1fr; max-width: 440px; }
  }
  /* ── Newsletter ── */
  .home-newsletter {
    background: var(--ivory-deep);
    padding: 96px 0;
    position: relative;
  }
  .home-newsletter::before {
    content: '';
    position: absolute; top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197,180,50,0.4), transparent);
  }

  .hn-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  .hn-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.8vw, 2.4rem);
    font-weight: 400;
    color: var(--dark);
    line-height: 1.22;
    margin-bottom: 16px;
  }
  .hn-title em { font-style: italic; color: var(--dark); font-weight: 500; }
  .hn-lead { font-size: 0.9rem; color: var(--text-soft); line-height: 1.8; font-weight: 300; }

  .hn-row {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }
  .hn-input {
    flex: 1;
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--dark);
    background: rgba(255,255,255,0.85);
    border: 1.5px solid rgba(44,44,44,0.14);
    border-radius: var(--radius);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    min-width: 0;
  }
  .hn-input::placeholder { color: var(--text-muted); }
  .hn-input:focus { border-color: rgba(197,180,50,0.6); box-shadow: 0 0 0 3px rgba(197,180,50,0.10); }
  .hn-input.is-error { border-color: #d94f4f; box-shadow: 0 0 0 3px rgba(217,79,79,0.10); }

  .hn-btn { padding: 14px 28px; white-space: nowrap; flex-shrink: 0; }

  .hn-error-msg {
    font-size: 0.76rem;
    color: #c0392b;
    margin-bottom: 10px;
    display: none;
  }
  .hn-error-msg.is-visible { display: block; }

  .hn-privacy {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  /* Success state */
  .hn-success {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    animation: fade-in-up 0.4s var(--ease) forwards;
  }
  .hn-success.is-visible { display: flex; }
  .hn-success-icon {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: rgba(197,180,50,0.12);
    border: 1.5px solid rgba(197,180,50,0.3);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-warm);
    margin-bottom: 8px;
  }
