---
const stats = [
  { num: "+5.000", label: "Procedimientos realizados" },
  { num: "+10",    label: "Años de experiencia" },
  { num: "98%",   label: "Clientes satisfechos" },
  { num: "+500",  label: "Reseñas verificadas" },
];
---

<section class="stats">
  <div class="stats-inner">
    {stats.map((s, i) => (
      <>
        <div class="stat">
          <div class="stat-num">{s.num}</div>
          <div class="stat-lbl">{s.label}</div>
        </div>
        {i < stats.length - 1 && <div class="stat-sep" aria-hidden="true" />}
      </>
    ))}
  </div>
</section>

<style>
  .stats {
    background: var(--dark);
    padding: 56px 32px;
    position: relative;
    overflow: hidden;
  }

  /* Single subtle gold rule at top */
  .stats::before {
    content: '';
    position: absolute; top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(213,192,57,0.35), transparent);
  }

  .stats-inner {
    max-width: 1180px; margin: 0 auto;
    display: flex; align-items: center; justify-content: center;
    gap: 0;
  }

  .stat {
    flex: 1; text-align: center; padding: 16px 40px;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 3.5vw, 3.2rem);
    font-weight: 300; font-style: italic;
    color: var(--gold);
    line-height: 1; margin-bottom: 10px;
    letter-spacing: -0.02em;
  }

  .stat-lbl {
    font-size: 0.73rem; font-weight: 400;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    line-height: 1.4;
  }

  .stat-sep {
    width: 1px; height: 56px; flex-shrink: 0;
    background: linear-gradient(to bottom, transparent, rgba(213,192,57,0.2), transparent);
  }

  @media (max-width: 720px) {
    .stats-inner { flex-wrap: wrap; gap: 0; }
    .stat { flex: 0 0 50%; padding: 24px 20px; }
    .stat-sep { display: none; }
    .stat:nth-child(1), .stat:nth-child(3) {
      border-right: 1px solid rgba(213,192,57,0.1);
    }
    .stat:nth-child(1), .stat:nth-child(2) {
      border-bottom: 1px solid rgba(213,192,57,0.1);
    }
  }
</style>
