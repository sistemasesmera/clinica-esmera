---
const stats = [
  { target: 5000, prefix: "+", suffix: "",  decimals: 0, display: "5.000", label: "Procedimientos realizados" },
  { target: 10,   prefix: "+", suffix: "",  decimals: 0, display: "10",    label: "Años de experiencia" },
  { target: 98,   prefix: "",  suffix: "%", decimals: 0, display: "98",    label: "Clientes satisfechos" },
  { target: 500,  prefix: "+", suffix: "",  decimals: 0, display: "500",   label: "Reseñas verificadas" },
];
---

<section class="stats" id="stats-section">
  <div class="stats-inner">
    {stats.map((s, i) => (
      <>
        <div class="stat">
          <div
            class="stat-num"
            data-target={s.target}
            data-prefix={s.prefix}
            data-suffix={s.suffix}
          >
            {s.prefix}{s.display}{s.suffix}
          </div>
          <div class="stat-lbl">{s.label}</div>
        </div>
        {i < stats.length - 1 && <div class="stat-sep" aria-hidden="true" />}
      </>
    ))}
  </div>
</section>

<script>
  function easeOutQuart(t: number): number {
    return 1 - Math.pow(1 - t, 4);
  }

  function formatNumber(n: number): string {
    // Format with dot as thousands separator (Spanish locale)
    return Math.floor(n).toLocaleString('es-ES');
  }

  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const prefix = el.dataset.prefix ?? '';
    const suffix = el.dataset.suffix ?? '';
    const duration = 1800;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const value = easeOutQuart(progress) * target;
      el.textContent = prefix + formatNumber(value) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll<HTMLElement>('.stat-num[data-target]').forEach(animateCounter);
          observer.disconnect();
        }
      });
    },
    { threshold: 0.4 }
  );

  const section = document.getElementById('stats-section');
  if (section) observer.observe(section);
</script>

<style>
  .stats {
    background: var(--dark);
    padding: 56px 32px;
    position: relative;
    overflow: hidden;
  }

  /* Single subtle gold rule at top */
  .stats::before {
    content: '';
    position: absolute; top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(213,192,57,0.35), transparent);
  }

  .stats-inner {
    max-width: 1180px; margin: 0 auto;
    display: flex; align-items: center; justify-content: center;
    gap: 0;
  }

  .stat {
    flex: 1; text-align: center; padding: 16px 40px;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 3.5vw, 3.2rem);
    font-weight: 300; font-style: italic;
    color: var(--gold);
    line-height: 1; margin-bottom: 10px;
    letter-spacing: -0.02em;
  }

  .stat-lbl {
    font-size: 0.73rem; font-weight: 400;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    line-height: 1.4;
  }

  .stat-sep {
    width: 1px; height: 56px; flex-shrink: 0;
    background: linear-gradient(to bottom, transparent, rgba(213,192,57,0.2), transparent);
  }

  @media (max-width: 720px) {
    .stats-inner { flex-wrap: wrap; gap: 0; }
    .stat { flex: 0 0 50%; padding: 24px 20px; }
    .stat-sep { display: none; }
    .stat:nth-child(1), .stat:nth-child(3) {
      border-right: 1px solid rgba(213,192,57,0.1);
    }
    .stat:nth-child(1), .stat:nth-child(2) {
      border-bottom: 1px solid rgba(213,192,57,0.1);
    }
  }
</style>
