---
const stats = [
  { target: 10000, prefix: "+", suffix: "",  decimals: 0, display: "5.000", label: "Procedimientos realizados" },
  { target: 10,   prefix: "+", suffix: "",  decimals: 0, display: "10",    label: "Años de experiencia" },
  { target: 98,   prefix: "",  suffix: "%", decimals: 0, display: "98",    label: "Clientes satisfechos" },
  { target: 400,  prefix: "+", suffix: "",  decimals: 0, display: "500",   label: "Reseñas verificadas" },
];
---

<section class="stats" id="stats-section">
  <div class="stats-inner">
    {stats.map((s, i) => (
      <>
        <div class="stat">
          <div
            class="stat-num"
            data-target={s.target}
            data-prefix={s.prefix}
            data-suffix={s.suffix}
          >
            {s.prefix}{s.display}{s.suffix}
          </div>
          <div class="stat-lbl">{s.label}</div>
        </div>
        {i < stats.length - 1 && <div class="stat-sep" aria-hidden="true" />}
      </>
    ))}
  </div>
</section>

<script>
  function easeOutQuart(t: number): number {
    return 1 - Math.pow(1 - t, 4);
  }

  function formatNumber(n: number): string {
    // Format with dot as thousands separator (Spanish locale)
    return Math.floor(n).toLocaleString('es-ES');
  }

  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const prefix = el.dataset.prefix ?? '';
    const suffix = el.dataset.suffix ?? '';
    const duration = 1800;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const value = easeOutQuart(progress) * target;
      el.textContent = prefix + formatNumber(value) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll<HTMLElement>('.stat-num[data-target]').forEach(animateCounter);
          observer.disconnect();
        }
      });
    },
    { threshold: 0.4 }
  );

  const section = document.getElementById('stats-section');
  if (section) observer.observe(section);
</script>

<style>
  .stats {
    background: linear-gradient(180deg, var(--ivory-mid) 0%, #E4E0D8 100%);
    padding: 64px 32px;
    position: relative;
    overflow: hidden;
  }

  /* Gold gradient line at top */
  .stats::before {
    content: '';
    position: absolute; top: 0; left: 6%; right: 6%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197,180,50,0.55), transparent);
  }

  /* Gold gradient line at bottom */
  .stats::after {
    content: '';
    position: absolute; bottom: 0; left: 6%; right: 6%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197,180,50,0.55), transparent);
  }

  .stats-inner {
    max-width: 1180px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stat {
    text-align: center; padding: 32px 24px;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 3.5vw, 3.2rem);
    font-weight: 200; font-style: italic;
    color: var(--dark);
    line-height: 1; margin-bottom: 10px;
    letter-spacing: -0.03em;
  }

  .stat-lbl {
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .stat-sep { display: none; }

  /* Separadores verticales entre columnas en desktop */
  .stat:not(:last-child) {
    border-right: 1px solid rgba(197,180,50,0.22);
  }

  /* 2×2 en mobile */
  @media (max-width: 640px) {
    .stats-inner { grid-template-columns: 1fr 1fr; }
    .stat { padding: 28px 16px; }
    .stat-num { font-size: clamp(2rem, 7vw, 2.4rem); }

    /* Resetear bordes y aplicar cuadrícula */
    .stat:not(:last-child) { border-right: none; }
    .stat:nth-child(1), .stat:nth-child(3) {
      border-right: 1px solid rgba(197,180,50,0.22);
    }
    .stat:nth-child(1), .stat:nth-child(2) {
      border-bottom: 1px solid rgba(197,180,50,0.22);
    }
  }
</style>
