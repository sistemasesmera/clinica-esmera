<style>
  .footer { background: var(--dark-rich); }

  .footer-top {
    padding: 80px 0 64px;
    position: relative;
  }
  .footer-top::before {
    content: '';
    position: absolute; top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(213,192,57,0.25), transparent);
  }

  .ft-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 56px;
  }

  /* Brand */
  .ft-logo { display: flex; align-items: baseline; gap: 5px; margin-bottom: 5px; }
  .ftl-clinica { font-family: var(--font-body); font-weight: 300; font-size: 0.75rem; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); text-transform: uppercase; }
  .ftl-esmera { font-family: var(--font-display); font-style: italic; font-size: 1.5rem; font-weight: 300; color: rgba(255,255,255,0.75); letter-spacing: 0.04em; }

  .ft-tagline { font-size: 0.65rem; letter-spacing: 0.25em; color: rgba(213,192,57,0.35); text-transform: uppercase; margin-bottom: 16px; }

  .ft-desc { font-size: 0.82rem; color: rgba(255,255,255,0.3); line-height: 1.72; margin-bottom: 24px; font-weight: 300; }

  .ft-social { display: flex; gap: 8px; }
  .soc {
    width: 34px; height: 34px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 2px;
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.35);
    transition: all var(--t);
  }
  .soc:hover { background: var(--gold); border-color: var(--gold); color: var(--dark); }

  /* Columns */
  .ft-col-h {
    font-family: var(--font-body);
    font-size: 0.65rem; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.25); margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(213,192,57,0.12);
  }

  .ft-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .ft-links li a { font-size: 0.82rem; color: rgba(255,255,255,0.38); font-weight: 300; transition: all 0.22s; letter-spacing: 0.02em; }
  .ft-links li a:hover { color: rgba(255,255,255,0.75); padding-left: 4px; }

  /* Contact */
  .ft-contact { list-style: none; display: flex; flex-direction: column; gap: 13px; margin-bottom: 24px; }
  .ft-contact li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.8rem; color: rgba(255,255,255,0.38); line-height: 1.5; font-weight: 300; }
  .ft-contact li svg { flex-shrink: 0; margin-top: 2px; }

  .ft-cta { padding: 11px 22px; font-size: 0.75rem; }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 20px 0;
  }
  .fb-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .footer-bottom p { font-size: 0.75rem; color: rgba(255,255,255,0.18); font-weight: 300; }
  .fb-links { display: flex; gap: 20px; }
  .fb-links a { font-size: 0.75rem; color: rgba(255,255,255,0.18); font-weight: 300; transition: color 0.2s; }
  .fb-links a:hover { color: rgba(213,192,57,0.6); }

  @media (max-width: 1024px) {
    .ft-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
  }

  @media (max-width: 560px) {
    .ft-grid { grid-template-columns: 1fr; gap: 36px; }
    .footer-top { padding: 56px 0 48px; }
    .fb-inner { flex-direction: column; text-align: center; }
  }
</style>
