---
const ofertas = [
  { tratamiento: "Radiofrecuencia",  antes: "80",  ahora: "55",  zona: "Facial" },
  { tratamiento: "HIFU Ultrafocal",  antes: "380", ahora: "290", zona: "Rostro completo" },
  { tratamiento: "Criolipólisis",    antes: "250", ahora: "190", zona: "Por zona" },
  { tratamiento: "Láser Depilatorio",antes: "120", ahora: "85",  zona: "Zona media" },
];
---

<section class="hero" id="inicio" aria-label="Portada">

  <!-- Carousel track -->
  <div class="carousel" id="heroCarousel">

    <!-- ──────────── SLIDE 1: Ofertas del mes ──────────── -->
    <div class="slide slide-1" data-slide="0" aria-label="Slide 1 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r1"></div>
        <div class="bg-radial bg-r2"></div>
      </div>

      <div class="slide-wrap s1-wrap">
        <!-- Left -->
        <div class="s1-left">
          <div class="hero-eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Clínica Esmera · Abril 2025</span>
          </div>
          <h1 class="hero-title">
            Ofertas<br />exclusivas<br />de <em>este mes</em>
          </h1>
          <p class="s1-sub">Plazas limitadas. Reserva antes de que se agoten.</p>
          <a href="/bonos" class="btn btn-gold s1-cta">
            Ver todos los bonos
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
          </a>
        </div>

        <!-- Right: price table card -->
        <div class="s1-right">
          <div class="price-card">
            <div class="pc-header">
              <span class="pc-col pc-col-trat">Tratamiento</span>
              <span class="pc-col pc-col-before">Antes</span>
              <span class="pc-col pc-col-after">Ahora</span>
            </div>
            {ofertas.map(o => (
              <a href="/nosotros#contacto" class="pc-row">
                <div class="pcr-info">
                  <span class="pcr-name">{o.tratamiento}</span>
                  <span class="pcr-zona">{o.zona}</span>
                </div>
                <span class="pcr-before">€{o.antes}</span>
                <div class="pcr-after-wrap">
                  <span class="pcr-after">€{o.ahora}</span>
                  <span class="pcr-save">Reservar →</span>
                </div>
              </a>
            ))}
            <p class="pc-note">* Precios por sesión. Sujeto a disponibilidad.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ──────────── SLIDE 2: Realza tu belleza ──────────── -->
    <div class="slide slide-2" data-slide="1" aria-label="Slide 2 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r3"></div>
      </div>

      <div class="slide-wrap s2-wrap">
        <!-- Left -->
        <div class="s2-left">
          <div class="hero-eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Medicina Estética · Madrid</span>
          </div>
          <h2 class="hero-title s2-title">
            Realza tu<br /><em>belleza natural</em>
          </h2>
          <p class="s2-lead">
            Medicina estética avanzada en Madrid.<br />
            Protocolos médicos personalizados para resultados reales y duraderos supervisados por especialistas.
          </p>
          <div class="s2-actions">
            <a
              href="https://wa.me/34600000000?text=Hola,%20me%20gustar%C3%ADa%20pedir%20cita%20en%20Cl%C3%ADnica%20Esmera"
              class="btn btn-whatsapp"
              target="_blank" rel="noopener"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Pide tu cita por WhatsApp
            </a>
            <a href="/medico-estetico/" class="btn btn-ghost">Ver tratamientos</a>
          </div>
          <p class="hero-footnote">Valoración médica gratuita · Sin compromiso</p>
        </div>

        <!-- Right: photo -->
        <div class="s2-right">
          <div class="s2-photo-wrap">
            <img
              src="/img/hero-modelo.jpg"
              alt="Medicina estética en Clínica Esmera Madrid"
              class="s2-photo"
              loading="eager"
            />
            <!-- Fallback / overlay ornament shown when no image -->
            <div class="s2-photo-fallback" aria-hidden="true">
              <div class="spf-inner">
                <span class="spf-clinic">C L Í N I C A</span>
                <span class="spf-name">Esmera</span>
                <span class="spf-city">· Madrid ·</span>
              </div>
            </div>
            <div class="s2-photo-tag">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="#19C771"><path d="M6.5 0C2.91 0 0 2.91 0 6.5S2.91 13 6.5 13 13 10.09 13 6.5 10.09 0 6.5 0zm-1.3 9.4L2.08 6.3l.9-.9 2.22 2.2 4.82-4.82.9.9-5.72 5.72z"/></svg>
              Médicos certificados
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ──────────── SLIDE 3: Tratamiento estrella ──────────── -->
    <div class="slide slide-3" data-slide="2" aria-label="Slide 3 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r4"></div>
        <div class="bg-radial bg-r5"></div>
      </div>

      <div class="slide-wrap s3-wrap">
        <!-- Badge -->
        <div class="s3-badge">
          <span class="s3b-orn">◈</span>
          Tratamiento estrella del mes
        </div>

        <div class="s3-content">
          <!-- Left: info -->
          <div class="s3-left">
            <div class="hero-eyebrow" style="margin-bottom:28px">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Aparatología · Abril 2025</span>
            </div>
            <h2 class="hero-title s3-title">
              HIFU<br /><em>Ultrafocal</em>
            </h2>
            <p class="s3-tagline">El lifting sin bisturí más eficaz del mercado</p>
            <p class="s3-desc">
              Ultrasonidos focalizados de alta intensidad que actúan en la capa más profunda de la piel. Resultados equivalentes a un lifting quirúrgico en una sola sesión, sin anestesia ni recuperación.
            </p>
            <a href="/nosotros#contacto" class="btn btn-gold s3-cta">
              Reservar precio especial
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
            </a>
            <p class="s3-footnote">Plazas limitadas · Oferta válida hasta fin de mes</p>
          </div>

          <!-- Right: price spotlight -->
          <div class="s3-right">
            <div class="s3-price-card">
              <p class="spc-label">Precio especial este mes</p>
              <div class="spc-prices">
                <div class="spc-before">
                  <span class="spcb-label">Precio habitual</span>
                  <span class="spcb-price">€380</span>
                </div>
                <div class="spc-arrow">→</div>
                <div class="spc-now">
                  <span class="spcn-label">Precio este mes</span>
                  <span class="spcn-price">€<em>290</em></span>
                </div>
              </div>
              <div class="spc-saving">Ahorra €90 · 24% de descuento</div>
              <div class="spc-divider"></div>
              <ul class="spc-includes">
                <li><span>✦</span> Valoración previa incluida</li>
                <li><span>✦</span> Protocolo facial completo</li>
                <li><span>✦</span> Seguimiento post-sesión</li>
                <li><span>✦</span> Efecto máximo a los 3 meses</li>
              </ul>
              <a href="/aparatologia/hifu" class="spc-link">
                Ver más sobre HIFU →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /carousel -->

  <!-- Controls -->
  <div class="carousel-controls" aria-label="Navegación del carrusel">
    <button class="cc-arrow cc-prev" id="heroPrev" aria-label="Slide anterior">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M13 4l-6 6 6 6"/></svg>
    </button>

    <div class="cc-dots" role="tablist" aria-label="Slides">
      <button class="cc-dot" data-dot="0" role="tab" aria-label="Ir al slide 1" aria-selected="true"></button>
      <button class="cc-dot" data-dot="1" role="tab" aria-label="Ir al slide 2" aria-selected="false"></button>
      <button class="cc-dot" data-dot="2" role="tab" aria-label="Ir al slide 3" aria-selected="false"></button>
    </div>

    <button class="cc-arrow cc-next" id="heroNext" aria-label="Slide siguiente">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7 4l6 6-6 6"/></svg>
    </button>
  </div>

  <!-- Scroll indicator (slide 1 only) -->
  <div class="hero-scroll" aria-hidden="true" id="heroScroll">
    <span class="scroll-bar"></span>
    <span class="scroll-text">Scroll</span>
  </div>

</section>

<style>
  /* ─── BASE ─── */
  .hero {
    min-height: 100vh;
    background: var(--dark-rich);
    position: relative; overflow: hidden;
  }

  /* ─── CAROUSEL ─── */
  .carousel {
    display: flex;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
  }

  .slide {
    min-width: 100%; min-height: 100vh;
    position: relative;
    display: flex; align-items: center;
    padding-top: 72px;
    transition: transform 0.65s cubic-bezier(0.77, 0, 0.175, 1);
    flex-shrink: 0;
  }

  /* Background glows */
  .slide-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .bg-radial {
    position: absolute; border-radius: 50%;
    filter: blur(100px); opacity: 0.09;
  }
  .bg-r1 { width: 600px; height: 600px; background: var(--gold); top: -200px; right: -100px; }
  .bg-r2 { width: 400px; height: 400px; background: var(--green); bottom: -150px; left: 5%; opacity: 0.05; }
  .bg-r3 { width: 700px; height: 700px; background: var(--gold); top: -250px; left: -150px; opacity: 0.07; }
  .bg-r4 { width: 500px; height: 500px; background: var(--gold); bottom: -100px; right: -80px; opacity: 0.08; }
  .bg-r5 { width: 300px; height: 300px; background: var(--green); top: -80px; left: 30%; opacity: 0.04; }

  /* Shared wrap */
  .slide-wrap {
    max-width: 1180px; width: 100%;
    margin: 0 auto;
    padding: 96px 32px;
    position: relative; z-index: 1;
  }

  /* Shared eyebrow */
  .hero-eyebrow {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 36px;
  }
  .eyebrow-line { display: block; width: 36px; height: 1px; background: var(--gold); opacity: 0.7; }
  .eyebrow-text { font-size: 0.68rem; font-weight: 400; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.38); }

  /* Shared title */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 400;
    color: rgba(255,255,255,0.92);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .hero-title em { font-style: italic; color: var(--gold); font-weight: 300; }

  /* Shared footnote */
  .hero-footnote { font-size: 0.72rem; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); font-weight: 300; }

  /* ─── SLIDE 1 ─── */
  .s1-wrap {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 72px; align-items: center;
  }
  .s1-left { display: flex; flex-direction: column; align-items: flex-start; gap: 0; }
  .s1-left .hero-title { margin-bottom: 16px; }
  .s1-sub { font-size: 0.85rem; color: rgba(255,255,255,0.38); font-weight: 300; margin-bottom: 36px; line-height: 1.6; }
  .s1-cta { }

  /* Price card */
  .price-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(213,192,57,0.15);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .pc-header {
    display: grid; grid-template-columns: 1fr 70px 90px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(213,192,57,0.12);
    background: rgba(213,192,57,0.06);
  }
  .pc-col { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.28); font-weight: 400; }
  .pc-col-before, .pc-col-after { text-align: right; }

  .pc-row {
    display: grid; grid-template-columns: 1fr 70px 90px;
    padding: 16px 20px; align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    text-decoration: none;
    transition: background 0.2s;
    cursor: pointer;
  }
  .pc-row:last-of-type { border-bottom: none; }
  .pc-row:hover { background: rgba(213,192,57,0.05); }

  .pcr-info { display: flex; flex-direction: column; gap: 3px; }
  .pcr-name { font-family: var(--font-display); font-size: 1rem; font-weight: 400; color: rgba(255,255,255,0.82); }
  .pcr-zona { font-size: 0.65rem; color: rgba(255,255,255,0.28); font-weight: 300; letter-spacing: 0.06em; }
  .pcr-before { font-size: 0.85rem; color: rgba(255,255,255,0.3); text-decoration: line-through; text-align: right; font-weight: 300; }

  .pcr-after-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .pcr-after { font-family: var(--font-display); font-size: 1.3rem; font-weight: 400; color: var(--gold); line-height: 1; }
  .pcr-save { font-size: 0.6rem; letter-spacing: 0.1em; color: rgba(213,192,57,0.5); text-transform: uppercase; opacity: 0; transition: opacity 0.2s; }
  .pc-row:hover .pcr-save { opacity: 1; }

  .pc-note { font-size: 0.65rem; color: rgba(255,255,255,0.18); padding: 10px 20px; font-weight: 300; border-top: 1px solid rgba(255,255,255,0.04); }

  /* ─── SLIDE 2 ─── */
  .s2-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px; align-items: center;
  }
  .s2-left { display: flex; flex-direction: column; gap: 0; }
  .s2-title { margin-bottom: 20px; }
  .s2-lead {
    font-size: 0.92rem; color: rgba(255,255,255,0.45); line-height: 1.8;
    font-weight: 300; margin-bottom: 36px;
  }
  .s2-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }

  /* WhatsApp btn */
  .btn-whatsapp {
    display: inline-flex; align-items: center; gap: 10px;
    background: #25D366; color: #fff;
    padding: 13px 22px;
    border-radius: var(--radius);
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em;
    text-decoration: none; text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-whatsapp:hover { background: #1ebe5d; transform: translateY(-1px); }

  /* Photo */
  .s2-right { display: flex; justify-content: center; }
  .s2-photo-wrap {
    position: relative; width: 100%; max-width: 440px;
    border-radius: 2px; overflow: hidden;
    aspect-ratio: 4/5;
  }
  .s2-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    display: block; z-index: 1;
  }
  /* Fallback shown when image is missing */
  .s2-photo-fallback {
    position: absolute; inset: 0; z-index: 0;
    background: linear-gradient(150deg, rgba(213,192,57,0.1), rgba(44,44,44,0.6), rgba(213,192,57,0.06));
    border: 1px solid rgba(213,192,57,0.15);
    display: flex; align-items: center; justify-content: center;
  }
  .spf-inner { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .spf-clinic { font-size: 0.55rem; letter-spacing: 0.5em; color: rgba(255,255,255,0.18); font-weight: 400; text-transform: uppercase; }
  .spf-name { font-family: var(--font-display); font-style: italic; font-size: 3rem; font-weight: 300; color: rgba(255,255,255,0.1); }
  .spf-city { font-size: 0.6rem; letter-spacing: 0.35em; color: rgba(213,192,57,0.2); font-weight: 300; }
  /* Hide fallback when real photo loads */
  .s2-photo:not([src=""]) ~ .s2-photo-fallback { opacity: 0; }

  .s2-photo-tag {
    position: absolute; bottom: 20px; left: 20px; z-index: 2;
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(250,249,245,0.96); border-radius: 2px;
    padding: 8px 14px;
    font-size: 0.72rem; font-weight: 500; color: var(--dark);
    letter-spacing: 0.04em; box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }

  /* ─── SLIDE 3 ─── */
  .s3-wrap { display: flex; flex-direction: column; }

  .s3-badge {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); font-weight: 400; margin-bottom: 40px;
    opacity: 0.85;
  }
  .s3b-orn { opacity: 0.6; }

  .s3-content {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px; align-items: center;
  }

  .s3-left { display: flex; flex-direction: column; }
  .s3-title { margin-bottom: 16px; }
  .s3-tagline {
    font-size: 1rem; color: rgba(255,255,255,0.45);
    font-weight: 300; margin-bottom: 20px; font-style: italic;
    font-family: var(--font-display);
  }
  .s3-desc {
    font-size: 0.88rem; color: rgba(255,255,255,0.38); line-height: 1.8;
    font-weight: 300; margin-bottom: 36px; max-width: 460px;
  }
  .s3-cta { margin-bottom: 20px; }
  .s3-footnote { font-size: 0.68rem; letter-spacing: 0.08em; color: rgba(255,255,255,0.2); font-weight: 300; }

  /* Price spotlight card */
  .s3-price-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(213,192,57,0.2);
    border-radius: var(--radius);
    padding: 40px 36px;
  }
  .spc-label {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.28); margin-bottom: 28px; font-weight: 400;
  }
  .spc-prices {
    display: flex; align-items: center; gap: 20px; margin-bottom: 16px;
  }
  .spc-before { display: flex; flex-direction: column; gap: 4px; }
  .spcb-label { font-size: 0.62rem; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; }
  .spcb-price { font-family: var(--font-display); font-size: 1.8rem; font-weight: 300; color: rgba(255,255,255,0.25); text-decoration: line-through; }
  .spc-arrow { font-size: 1.2rem; color: rgba(213,192,57,0.4); }
  .spc-now { display: flex; flex-direction: column; gap: 4px; }
  .spcn-label { font-size: 0.62rem; color: var(--gold); letter-spacing: 0.08em; opacity: 0.8; }
  .spcn-price { font-family: var(--font-display); font-size: 3.2rem; font-weight: 300; color: rgba(255,255,255,0.92); line-height: 1; }
  .spcn-price em { font-style: normal; color: var(--gold); }
  .spc-saving {
    display: inline-block; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 24px; opacity: 0.8;
  }
  .spc-divider { width: 100%; height: 1px; background: rgba(213,192,57,0.12); margin-bottom: 20px; }
  .spc-includes { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
  .spc-includes li { display: flex; align-items: center; gap: 10px; font-size: 0.82rem; color: rgba(255,255,255,0.4); font-weight: 300; }
  .spc-includes li span { color: var(--gold); opacity: 0.6; font-size: 0.55rem; }
  .spc-link {
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(213,192,57,0.6); border-bottom: 1px solid rgba(213,192,57,0.2);
    padding-bottom: 2px; text-decoration: none; transition: all 0.2s;
    display: inline-block;
  }
  .spc-link:hover { color: var(--gold); border-color: var(--gold); }

  /* ─── CONTROLS ─── */
  .carousel-controls {
    position: absolute; bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; align-items: center; gap: 20px;
    z-index: 10;
  }

  .cc-arrow {
    width: 40px; height: 40px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 2px; background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.45);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s;
    backdrop-filter: blur(8px);
  }
  .cc-arrow:hover { background: rgba(213,192,57,0.12); border-color: rgba(213,192,57,0.4); color: var(--gold); }

  .cc-dots { display: flex; gap: 8px; }
  .cc-dot {
    width: 24px; height: 2px;
    background: rgba(255,255,255,0.2);
    border: none; cursor: pointer;
    border-radius: 2px;
    transition: all 0.3s;
    padding: 0;
  }
  .cc-dot.is-active { background: var(--gold); width: 40px; }

  /* ─── SCROLL INDICATOR ─── */
  .hero-scroll {
    position: absolute; bottom: 100px; right: 40px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    color: rgba(255,255,255,0.2);
    font-size: 0.6rem; letter-spacing: 0.25em;
    text-transform: uppercase;
    z-index: 5;
    transition: opacity 0.4s;
  }
  .hero-scroll.is-hidden { opacity: 0; pointer-events: none; }
  .scroll-bar {
    display: block; width: 1px; height: 40px;
    background: linear-gradient(to bottom, transparent, rgba(213,192,57,0.45));
    animation: scrollbar 2.5s infinite var(--ease);
  }
  @keyframes scrollbar {
    0%, 100% { opacity: 0.5; transform: scaleY(1); }
    50% { opacity: 0.2; transform: scaleY(0.5); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .s1-wrap, .s2-wrap, .s3-content {
      grid-template-columns: 1fr; gap: 48px;
    }
    .s2-right { order: -1; }
    .s2-photo-wrap { max-width: 300px; margin: 0 auto; }
    .hero-scroll { right: 20px; bottom: 90px; }
    .s3-wrap { padding-top: 80px; }
  }

  @media (max-width: 640px) {
    .slide-wrap { padding: 80px 20px 120px; }
    .hero-title { font-size: 2.6rem; }
    .s2-actions { flex-direction: column; }
    .btn-whatsapp, .btn-ghost { width: 100%; justify-content: center; }
    .spc-prices { flex-direction: column; gap: 12px; }
    .spc-arrow { transform: rotate(90deg); }
    .s3-price-card { padding: 28px 20px; }
    .hero-scroll { display: none; }
    .carousel-controls { bottom: 24px; gap: 14px; }
  }
</style>

<script>
  (function () {
    const carousel = document.getElementById('heroCarousel');
    const slides = carousel.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.cc-dot');
    const prevBtn = document.getElementById('heroPrev');
    const nextBtn = document.getElementById('heroNext');
    const scrollInd = document.getElementById('heroScroll');

    let current = 0;
    const total = slides.length;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      current = (index + total) % total;

      // Move all slides by the same amount — each slide's flex position
      // handles the individual offsets, so we just apply -current*100%
      slides.forEach((slide) => {
        (slide as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      });

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
        dot.setAttribute('aria-selected', String(i === current));
      });

      // Hide scroll indicator on non-first slides
      if (scrollInd) {
        scrollInd.classList.toggle('is-hidden', current !== 0);
      }
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(() => goTo(current + 1), 5500);
    }

    function stopAuto() {
      if (autoTimer) clearInterval(autoTimer);
    }

    // Init: all slides at translateX(0) — flex places them correctly side by side
    slides.forEach((slide) => {
      (slide as HTMLElement).style.transform = `translateX(0%)`;
    });
    dots[0]?.classList.add('is-active');

    prevBtn?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        stopAuto();
        goTo(parseInt(dot.getAttribute('data-dot') || '0'));
        startAuto();
      });
    });

    // Touch/swipe support
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const delta = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(delta) > 50) {
        stopAuto();
        goTo(delta < 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    startAuto();
  })();
</script>
