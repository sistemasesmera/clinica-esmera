---
const ofertas = [
  { tratamiento: "Radiofrecuencia",  antes: "80",  ahora: "55",  zona: "Facial" },
  { tratamiento: "HIFU Ultrafocal",  antes: "380", ahora: "290", zona: "Rostro completo" },
  { tratamiento: "Criolipólisis",    antes: "250", ahora: "190", zona: "Por zona" },
  { tratamiento: "Láser Depilatorio",antes: "120", ahora: "85",  zona: "Zona media" },
];
---

<section class="hero" id="inicio" aria-label="Portada">

  <div class="carousel" id="heroCarousel">

    <!-- ──────────── SLIDE 1: Ofertas del mes ──────────── -->
    <div class="slide slide-1" data-slide="0" aria-label="Slide 1 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r1"></div>
        <div class="bg-radial bg-r2"></div>
      </div>

      <div class="slide-wrap s1-wrap">
        <div class="s1-left">
          <div class="hero-eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Clínica Esmera · Abril 2025</span>
          </div>
          <h1 class="hero-title">
            Ofertas<br />exclusivas<br />de <em>este mes</em>
          </h1>
          <p class="s1-sub">Plazas limitadas. Reserva antes de que se agoten.</p>
          <a href="/bonos" class="btn btn-gold s1-cta">
            Ver todos los bonos
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
          </a>
        </div>

        <div class="s1-right">
          <div class="price-card">
            <div class="pc-header">
              <span class="pc-col pc-col-trat">Tratamiento</span>
              <span class="pc-col pc-col-before">Antes</span>
              <span class="pc-col pc-col-after">Ahora</span>
            </div>
            {ofertas.map(o => (
              <a href="/nosotros#contacto" class="pc-row">
                <div class="pcr-info">
                  <span class="pcr-name">{o.tratamiento}</span>
                  <span class="pcr-zona">{o.zona}</span>
                </div>
                <span class="pcr-before">€{o.antes}</span>
                <div class="pcr-after-wrap">
                  <span class="pcr-after">€{o.ahora}</span>
                  <span class="pcr-save">Reservar →</span>
                </div>
              </a>
            ))}
            <p class="pc-note">* Precios por sesión. Sujeto a disponibilidad.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ──────────── SLIDE 2: Realza tu belleza ──────────── -->
    <div class="slide slide-2" data-slide="1" aria-label="Slide 2 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r3"></div>
      </div>

      <div class="slide-wrap s2-wrap">
        <div class="s2-left">
          <div class="hero-eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Medicina Estética · Madrid</span>
          </div>
          <h2 class="hero-title s2-title">
            Realza tu<br /><em>belleza natural</em>
          </h2>
          <p class="s2-lead">
            Medicina estética avanzada en Madrid.<br />
            Protocolos médicos personalizados para resultados reales y duraderos supervisados por especialistas.
          </p>
          <div class="s2-actions">
            <a
              href="https://wa.me/34600000000?text=Hola,%20me%20gustar%C3%ADa%20pedir%20cita%20en%20Cl%C3%ADnica%20Esmera"
              class="btn btn-whatsapp"
              target="_blank" rel="noopener"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Pide tu cita por WhatsApp
            </a>
            <a href="/medico-estetico/" class="btn btn-ghost-hero">Ver tratamientos</a>
          </div>
          <p class="hero-footnote">Valoración médica gratuita · Sin compromiso</p>
        </div>

        <div class="s2-right">
          <div class="s2-photo-wrap">
            <img
              src="https://picsum.photos/seed/esmera-modelo/440/550"
              alt="Medicina estética en Clínica Esmera Madrid"
              class="s2-photo"
              loading="eager"
            />
            <div class="s2-photo-fallback" aria-hidden="true">
              <div class="spf-inner">
                <span class="spf-clinic">C L Í N I C A</span>
                <span class="spf-name">Esmera</span>
                <span class="spf-city">· Madrid ·</span>
              </div>
            </div>
            <div class="s2-photo-tag">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="#19C771"><path d="M6.5 0C2.91 0 0 2.91 0 6.5S2.91 13 6.5 13 13 10.09 13 6.5 10.09 0 6.5 0zm-1.3 9.4L2.08 6.3l.9-.9 2.22 2.2 4.82-4.82.9.9-5.72 5.72z"/></svg>
             Confianza
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ──────────── SLIDE 3: Tratamiento estrella ──────────── -->
    <div class="slide slide-3" data-slide="2" aria-label="Slide 3 de 3">
      <div class="slide-bg" aria-hidden="true">
        <div class="bg-radial bg-r4"></div>
        <div class="bg-radial bg-r5"></div>
      </div>

      <div class="slide-wrap s3-wrap">
        <div class="s3-badge">
          <span class="s3b-star">★</span>
          Tratamiento estrella del mes
        </div>

        <div class="s3-content">
          <div class="s3-left">
            <div class="hero-eyebrow" style="margin-bottom:28px">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Aparatología · Abril 2025</span>
            </div>
            <h2 class="hero-title s3-title">
              HIFU<br /><em>Ultrafocal</em>
            </h2>
            <p class="s3-tagline">El lifting sin bisturí más eficaz del mercado</p>
            <p class="s3-desc">
              Ultrasonidos focalizados de alta intensidad que actúan en la capa más profunda de la piel. Resultados equivalentes a un lifting quirúrgico en una sola sesión, sin anestesia ni recuperación.
            </p>
            <a href="/nosotros#contacto" class="btn btn-gold s3-cta">
              Reservar precio especial
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
            </a>
            <p class="s3-footnote">Plazas limitadas · Oferta válida hasta fin de mes</p>
          </div>

          <div class="s3-right">
            <div class="s3-price-card">
              <p class="spc-label">Precio especial este mes</p>
              <div class="spc-prices">
                <div class="spc-before">
                  <span class="spcb-label">Precio habitual</span>
                  <span class="spcb-price">€380</span>
                </div>
                <div class="spc-arrow">→</div>
                <div class="spc-now">
                  <span class="spcn-label">Precio este mes</span>
                  <span class="spcn-price">€<em>290</em></span>
                </div>
              </div>
              <div class="spc-saving">Ahorra €90 · 24% de descuento</div>
              <div class="spc-divider"></div>
              <ul class="spc-includes">
                <li><span>✦</span> Valoración previa incluida</li>
                <li><span>✦</span> Protocolo facial completo</li>
                <li><span>✦</span> Seguimiento post-sesión</li>
                <li><span>✦</span> Efecto máximo a los 3 meses</li>
              </ul>
              <a href="/aparatologia/hifu" class="spc-link">
                Ver más sobre HIFU →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /carousel -->

  <!-- Flecha izquierda -->
  <button class="cc-arrow cc-prev" id="heroPrev" aria-label="Slide anterior">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M13 4l-6 6 6 6"/></svg>
  </button>

  <!-- Puntos indicadores -->
  <div class="cc-dots" role="tablist" aria-label="Slides">
    <button class="cc-dot" data-dot="0" role="tab" aria-label="Ir al slide 1" aria-selected="true"></button>
    <button class="cc-dot" data-dot="1" role="tab" aria-label="Ir al slide 2" aria-selected="false"></button>
    <button class="cc-dot" data-dot="2" role="tab" aria-label="Ir al slide 3" aria-selected="false"></button>
  </div>

  <!-- Flecha derecha -->
  <button class="cc-arrow cc-next" id="heroNext" aria-label="Slide siguiente">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7 4l6 6-6 6"/></svg>
  </button>

  <!-- Scroll indicator (slide 1 only) -->
  <div class="hero-scroll" aria-hidden="true" id="heroScroll">
    <span class="scroll-bar"></span>
  </div>

</section>

<style>
  /* ─── BASE ─── */
  .hero {
    min-height: 100vh;
    background: var(--ivory-deep);
    position: relative;
    overflow: hidden;
  }

  /* ─── CAROUSEL ─── */
  .carousel {
    display: flex;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
  }

  .slide {
    min-width: 100%;
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    padding-top: 72px;
    transition: transform 0.65s cubic-bezier(0.77, 0, 0.175, 1);
    flex-shrink: 0;
  }

  /* Simulated background images per slide */
  .slide-1 {
    background-image: url('https://picsum.photos/seed/esmera-promo/1920/1080');
    background-size: cover;
    background-position: center;
  }
  .slide-2 {
    background-image: url('https://picsum.photos/seed/esmera-bella/1920/1080');
    background-size: cover;
    background-position: center top;
  }
  .slide-3 {
    background-image: url('https://picsum.photos/seed/esmera-hifu/1920/1080');
    background-size: cover;
    background-position: center;
  }

  /* Beige overlay on each slide */
  .slide::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(237, 233, 220, 0.86);
    z-index: 0;
    pointer-events: none;
  }

  /* Background glows — warm gold tones on beige */
  .slide-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }
  .bg-radial {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.12;
  }
  .bg-r1 { width: 600px; height: 600px; background: var(--gold); top: -200px; right: -100px; }
  .bg-r2 { width: 400px; height: 400px; background: var(--gold-warm); bottom: -150px; left: 5%; opacity: 0.07; }
  .bg-r3 { width: 700px; height: 700px; background: var(--gold); top: -250px; left: -150px; opacity: 0.09; }
  .bg-r4 { width: 500px; height: 500px; background: var(--gold); bottom: -100px; right: -80px; opacity: 0.10; }
  .bg-r5 { width: 300px; height: 300px; background: var(--gold-warm); top: -80px; left: 30%; opacity: 0.06; }

  /* Shared wrap */
  .slide-wrap {
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    padding: 96px 32px;
    position: relative;
    z-index: 2;
  }

  /* Shared eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
  }
  .eyebrow-line { display: block; width: 36px; height: 1px; background: var(--gold-warm); opacity: 0.8; }
  .eyebrow-text {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Shared title */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 400;
    color: var(--dark);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .hero-title em { font-style: italic; color: var(--gold-warm); font-weight: 300; }

  /* Shared footnote */
  .hero-footnote {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 300;
  }

  /* Ghost button override for light hero */
  .btn-ghost-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    background: transparent;
    color: var(--dark);
    padding: 14px 34px;
    border-radius: var(--radius);
    border: 1.5px solid rgba(44, 44, 44, 0.28);
    transition: all var(--t) var(--ease);
  }
  .btn-ghost-hero:hover {
    border-color: rgba(44, 44, 44, 0.65);
    background: rgba(44, 44, 44, 0.06);
  }

  /* ─── SLIDE 1 ─── */
  .s1-wrap {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 72px;
    align-items: center;
  }
  .s1-left { display: flex; flex-direction: column; align-items: flex-start; }
  .s1-left .hero-title { margin-bottom: 16px; }
  .s1-sub {
    font-size: 0.85rem;
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 36px;
    line-height: 1.6;
  }

  /* Price card */
  .price-card {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(197, 180, 50, 0.25);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 4px 28px rgba(44, 44, 44, 0.08);
    backdrop-filter: blur(12px);
  }
  .pc-header {
    display: grid;
    grid-template-columns: 1fr 70px 90px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(197, 180, 50, 0.2);
    background: rgba(213, 192, 57, 0.09);
  }
  .pc-col {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
  }
  .pc-col-before, .pc-col-after { text-align: right; }

  .pc-row {
    display: grid;
    grid-template-columns: 1fr 70px 90px;
    padding: 16px 20px;
    align-items: center;
    border-bottom: 1px solid rgba(44, 44, 44, 0.05);
    text-decoration: none;
    transition: background 0.2s;
    cursor: pointer;
  }
  .pc-row:last-of-type { border-bottom: none; }
  .pc-row:hover { background: rgba(213, 192, 57, 0.08); }

  .pcr-info { display: flex; flex-direction: column; gap: 3px; }
  .pcr-name { font-family: var(--font-display); font-size: 1rem; font-weight: 400; color: var(--dark); }
  .pcr-zona { font-size: 0.65rem; color: var(--text-muted); font-weight: 300; letter-spacing: 0.06em; }
  .pcr-before { font-size: 0.85rem; color: rgba(44, 44, 44, 0.35); text-decoration: line-through; text-align: right; font-weight: 300; }

  .pcr-after-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .pcr-after { font-family: var(--font-display); font-size: 1.3rem; font-weight: 400; color: var(--gold-warm); line-height: 1; }
  .pcr-save { font-size: 0.6rem; letter-spacing: 0.1em; color: var(--gold-warm); text-transform: uppercase; opacity: 0; transition: opacity 0.2s; }
  .pc-row:hover .pcr-save { opacity: 0.8; }

  .pc-note { font-size: 0.65rem; color: var(--text-muted); padding: 10px 20px; font-weight: 300; border-top: 1px solid rgba(44, 44, 44, 0.05); }

  /* ─── SLIDE 2 ─── */
  .s2-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .s2-left { display: flex; flex-direction: column; gap: 0; }
  .s2-title { margin-bottom: 20px; }
  .s2-lead {
    font-size: 0.92rem;
    color: var(--text-soft);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 36px;
  }
  .s2-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    padding: 13px 22px;
    border-radius: var(--radius);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-whatsapp:hover { background: #1ebe5d; transform: translateY(-1px); }

  /* Photo */
  .s2-right { display: flex; justify-content: center; }
  .s2-photo-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 4/5;
    box-shadow: 0 12px 48px rgba(44, 44, 44, 0.16);
  }
  .s2-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    z-index: 1;
  }
  .s2-photo-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(150deg, rgba(213,192,57,0.15), rgba(220,215,200,0.7), rgba(213,192,57,0.10));
    border: 1px solid rgba(197,180,50,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .spf-inner { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .spf-clinic { font-size: 0.55rem; letter-spacing: 0.5em; color: rgba(44,44,44,0.3); font-weight: 400; text-transform: uppercase; }
  .spf-name { font-family: var(--font-display); font-style: italic; font-size: 3rem; font-weight: 300; color: rgba(44,44,44,0.15); }
  .spf-city { font-size: 0.6rem; letter-spacing: 0.35em; color: rgba(197,180,50,0.5); font-weight: 300; }
  .s2-photo:not([src=""]) ~ .s2-photo-fallback { opacity: 0; }

  .s2-photo-tag {
    position: absolute;
    bottom: 20px;
    left: 20px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.96);
    border-radius: 2px;
    padding: 8px 14px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--dark);
    letter-spacing: 0.04em;
    box-shadow: 0 4px 16px rgba(44,44,44,0.15);
  }

  /* ─── SLIDE 3 ─── */
  .s3-wrap { display: flex; flex-direction: column; }

  .s3-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-warm);
    font-weight: 500;
    margin-bottom: 40px;
  }
  .s3b-star {
    font-size: 1.5rem;
    line-height: 1;
    color: var(--gold-warm);
    opacity: 0.9;
    filter: drop-shadow(0 1px 4px rgba(197,180,50,0.4));
  }

  .s3-content {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: center;
  }

  .s3-left { display: flex; flex-direction: column; }
  .s3-title { margin-bottom: 16px; }
  .s3-tagline {
    font-size: 1rem;
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 20px;
    font-style: italic;
    font-family: var(--font-display);
  }
  .s3-desc {
    font-size: 0.88rem;
    color: var(--text-soft);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 36px;
    max-width: 460px;
  }
  .s3-cta { margin-bottom: 20px; }
  .s3-footnote { font-size: 0.68rem; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 300; }

  /* Price spotlight card */
  .s3-price-card {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(197, 180, 50, 0.28);
    border-radius: var(--radius);
    padding: 40px 36px;
    box-shadow: 0 8px 40px rgba(44, 44, 44, 0.09);
    backdrop-filter: blur(12px);
  }
  .spc-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 28px;
