<script>
  (function () {
    const carousel = document.getElementById('heroCarousel');
    const slides = carousel.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.cc-dot');
    const prevBtn = document.getElementById('heroPrev');
    const nextBtn = document.getElementById('heroNext');
    const scrollInd = document.getElementById('heroScroll');

    let current = 0;
    const total = slides.length;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      current = (index + total) % total;

      slides.forEach((slide) => {
        (slide as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
        dot.setAttribute('aria-selected', String(i === current));
      });

      if (scrollInd) {
        scrollInd.classList.toggle('is-hidden', current !== 0);
      }
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(() => goTo(current + 1), 9500);
    }

    function stopAuto() {
      if (autoTimer) clearInterval(autoTimer);
    }

    slides.forEach((slide) => {
      (slide as HTMLElement).style.transform = `translateX(0%)`;
    });
    dots[0]?.classList.add('is-active');

    prevBtn?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        stopAuto();
        goTo(parseInt(dot.getAttribute('data-dot') || '0'));
        startAuto();
      });
    });

    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const delta = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(delta) > 50) {
        stopAuto();
        goTo(delta < 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    startAuto();
  })();
</script>
