---
---
<section class="hero" id="inicio">
  <div class="hero-bg" aria-hidden="true">
    <div class="bg-radial bg-r1"></div>
    <div class="bg-radial bg-r2"></div>
  </div>

  <div class="hero-wrap">
    <!-- Left column -->
    <div class="hero-left">

      <div class="hero-eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">Madrid · Estética & Medicina Estética</span>
      </div>

      <h1 class="hero-title">
        La belleza que<br />
        buscas <em>existe.</em><br />
        Nosotros la<br />
        <em>hacemos realidad.</em>
      </h1>

      <div class="hero-divider" aria-hidden="true"></div>

      <!-- Offer -->
      <div class="hero-offer">
        <div class="offer-orn">✦</div>
        <div class="offer-body">
          <p class="offer-label">Oferta de bienvenida</p>
          <p class="offer-headline">
            Primera consulta <em>gratuita</em> + 40% en tu primer tratamiento
          </p>
        </div>
      </div>

      <div class="hero-actions">
        <a href="#contacto" class="btn btn-gold">
          Reserva tu consulta
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
        </a>
        <a href="#estetico" class="btn btn-ghost">Descubrir tratamientos</a>
      </div>

      <p class="hero-footnote">
        Sin compromiso · Atención personalizada · Resultados reales
      </p>
    </div>

    <!-- Right column: editorial visual -->
    <div class="hero-right" aria-hidden="true">
      <div class="vis-outer">
        <div class="vis-card">
          <!-- Editorial composition -->
          <div class="vis-composition">
            <div class="comp-oval comp-o1"></div>
            <div class="comp-oval comp-o2"></div>
            <div class="comp-rule"></div>
            <div class="comp-brand">
              <span class="cb-top">C L Í N I C A</span>
              <span class="cb-main">Esmera</span>
              <span class="cb-sub">· Madrid ·</span>
            </div>
            <div class="comp-since">Est. 2014</div>
          </div>
        </div>

        <!-- Floating proofs -->
        <div class="proof proof-a">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#19C771"><path d="M7 0C3.13 0 0 3.13 0 7s3.13 7 7 7 7-3.13 7-7S10.87 0 7 0zm-1.4 10.08L2.45 6.93l.98-.98 2.17 2.16 4.97-4.96.98.98-5.95 5.95z"/></svg>
          Tecnología certificada
        </div>
        <div class="proof proof-b">
          <span class="stars">★★★★★</span>
          4.9 · +500 reseñas
        </div>
        <div class="proof proof-c">
          +5.000 procedimientos realizados
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span class="scroll-bar"></span>
    <span class="scroll-text">Scroll</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--dark-rich);
    position: relative; overflow: hidden;
    display: flex; align-items: center;
    padding-top: 72px;
  }

  /* Subtle background glows — no harsh patterns */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .bg-radial {
    position: absolute; border-radius: 50%;
    filter: blur(100px); opacity: 0.09;
  }
  .bg-r1 {
    width: 600px; height: 600px;
    background: var(--gold);
    top: -200px; right: -100px;
  }
  .bg-r2 {
    width: 400px; height: 400px;
    background: var(--green);
    bottom: -150px; left: 5%; opacity: 0.05;
  }

  /* Layout */
  .hero-wrap {
    max-width: 1180px; margin: 0 auto;
    padding: 96px 32px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
    position: relative; z-index: 1;
    width: 100%;
  }

  /* ── LEFT ── */
  .hero-eyebrow {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 36px;
  }
  .eyebrow-line {
    display: block; width: 36px; height: 1px; background: var(--gold); opacity: 0.7;
  }
  .eyebrow-text {
    font-size: 0.68rem; font-weight: 400;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.38);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4.5vw, 4.4rem);
    font-weight: 400;
    color: rgba(255,255,255,0.92);
    line-height: 1.2;
    margin-bottom: 36px;
    letter-spacing: -0.01em;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 300;
  }

  .hero-divider {
    width: 48px; height: 1px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin-bottom: 32px;
    opacity: 0.6;
  }

  /* Offer */
  .hero-offer {
    display: flex; gap: 18px; align-items: flex-start;
    margin-bottom: 40px;
    padding: 22px 24px;
    border: 1px solid rgba(213,192,57,0.18);
    border-radius: var(--radius);
    background: rgba(213,192,57,0.04);
  }
  .offer-orn {
    font-size: 0.9rem; color: var(--gold);
    opacity: 0.7; flex-shrink: 0;
    margin-top: 3px;
  }
  .offer-label {
    font-size: 0.68rem; letter-spacing: 0.2em;
    text-transform: uppercase; font-weight: 500;
    color: var(--gold); opacity: 0.8; margin-bottom: 7px;
  }
  .offer-headline {
    font-family: var(--font-display);
    font-size: 1.2rem; font-weight: 400;
    color: rgba(255,255,255,0.82);
    line-height: 1.4;
  }
  .offer-headline em { font-style: italic; color: var(--gold); }

  /* Actions */
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }

  .hero-footnote {
    font-size: 0.72rem; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25);
    font-weight: 300;
  }

  /* ── RIGHT ── */
  .hero-right { display: flex; justify-content: center; }

  .vis-outer {
    position: relative;
    width: 100%; max-width: 440px;
  }

  .vis-card {
    border-radius: 2px; overflow: hidden;
    aspect-ratio: 4/5;
    background: linear-gradient(
      150deg,
      rgba(213,192,57,0.1) 0%,
      rgba(44,44,44,0.5) 50%,
      rgba(213,192,57,0.06) 100%
    );
    border: 1px solid rgba(213,192,57,0.15);
    position: relative;
  }

  /* Editorial composition inside */
  .vis-composition {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }

  .comp-oval {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(213,192,57,0.12);
  }
  .comp-o1 {
    width: 260px; height: 320px;
    top: 50%; left: 50%;
    transform: translate(-50%, -52%);
    background: radial-gradient(ellipse at 40% 35%, rgba(213,192,57,0.09), transparent 65%);
  }
  .comp-o2 {
    width: 160px; height: 200px;
    top: 50%; left: 50%;
    transform: translate(-50%, -52%);
    border-color: rgba(213,192,57,0.08);
  }
  .comp-rule {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) translateY(-80px);
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(213,192,57,0.3), transparent);
  }

  .comp-brand {
    display: flex; flex-direction: column;
    align-items: center; gap: 6px;
    position: absolute; bottom: 22%;
  }
  .cb-top {
    font-family: var(--font-body);
    font-size: 0.55rem; font-weight: 400;
    letter-spacing: 0.5em; color: rgba(255,255,255,0.18);
    text-transform: uppercase;
  }
  .cb-main {
    font-family: var(--font-display);
    font-style: italic; font-size: 2.6rem; font-weight: 300;
    color: rgba(255,255,255,0.12); letter-spacing: 0.05em;
  }
  .cb-sub {
    font-size: 0.6rem; letter-spacing: 0.4em;
    color: rgba(213,192,57,0.25); font-weight: 300;
    text-transform: uppercase;
  }
  .comp-since {
    position: absolute; top: 20px; right: 20px;
    font-size: 0.6rem; letter-spacing: 0.2em;
    color: rgba(213,192,57,0.3); text-transform: uppercase;
    font-weight: 300;
  }

  /* Floating proofs */
  .proof {
    position: absolute;
    background: rgba(250,249,245,0.97);
    border-radius: 2px;
    padding: 10px 16px;
    font-size: 0.75rem; font-weight: 500;
    color: var(--dark);
    box-shadow: var(--shadow-mid);
    display: flex; align-items: center; gap: 8px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .proof-a { top: 20px; right: -20px; }
  .proof-b { bottom: 28%; left: -24px; gap: 6px; }
  .proof-c {
    bottom: 10%; right: 8px;
    background: var(--dark);
    color: rgba(255,255,255,0.75);
    font-size: 0.7rem; letter-spacing: 0.06em;
  }
  .stars { color: var(--gold); letter-spacing: 1px; font-size: 0.8rem; }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute; bottom: 32px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column;
    align-items: center; gap: 10px;
    color: rgba(255,255,255,0.2);
    font-size: 0.6rem; letter-spacing: 0.25em;
    text-transform: uppercase;
  }
  .scroll-bar {
    display: block; width: 1px; height: 48px;
    background: linear-gradient(to bottom, transparent, rgba(213,192,57,0.45));
    animation: scrollbar 2.5s infinite var(--ease);
  }
  @keyframes scrollbar {
    0%, 100% { opacity: 0.5; transform: scaleY(1); }
    50% { opacity: 0.2; transform: scaleY(0.5); }
  }

  /* Responsive */
  @media (max-width: 920px) {
    .hero-wrap { grid-template-columns: 1fr; text-align: center; gap: 56px; }
    .hero-right { order: -1; }
    .vis-outer { max-width: 320px; }
    .hero-eyebrow { justify-content: center; }
    .hero-divider { margin: 0 auto 32px; }
    .hero-actions { justify-content: center; }
    .hero-footnote { text-align: center; }
    .hero-offer { text-align: left; }
    .proof-a { right: -8px; }
    .proof-b { left: -8px; }
  }

  @media (max-width: 480px) {
    .hero-title { font-size: 2.6rem; }
    .hero-wrap { padding: 72px 24px; }
    .vis-outer { max-width: 270px; }
    .proof-b { display: none; }
    .hero-actions { flex-direction: column; align-items: center; }
    .btn { width: 100%; justify-content: center; }
  }
</style>
