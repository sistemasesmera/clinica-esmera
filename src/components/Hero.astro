---
---
<section class="hero" id="inicio">
  <!-- Background decorations -->
  <div class="bg-deco" aria-hidden="true">
    <div class="bg-glow bg-glow-1"></div>
    <div class="bg-glow bg-glow-2"></div>
    <div class="bg-grid"></div>
  </div>

  <div class="container hero-grid">
    <!-- LEFT: Content -->
    <div class="hero-content">
      <div class="live-badge">
        <span class="live-dot"></span>
        Oferta de Bienvenida — Plazas limitadas
      </div>

      <h1 class="hero-h1">
        Tu versión más<br />
        <em class="gold-italic">radiante</em><br />
        comienza aquí
      </h1>

      <p class="hero-desc">
        Estética y medicina estética de primer nivel. Tecnología avanzada,
        profesionales certificados y resultados que puedes ver desde la
        primera sesión.
      </p>

      <!-- Offer highlight box -->
      <div class="offer-box">
        <div class="offer-star">✦</div>
        <div>
          <p class="offer-label">OFERTA EXCLUSIVA DE BIENVENIDA</p>
          <p class="offer-text">
            Primera consulta <strong>GRATUITA</strong> + 40% dto. en tu primer tratamiento
          </p>
        </div>
        <div class="offer-badge">HOY</div>
      </div>

      <div class="hero-btns">
        <a href="#contacto" class="btn btn-gold btn-hero">
          Reserva tu cita gratis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4"/>
          </svg>
        </a>
        <a href="#estetico" class="btn btn-outline-white btn-hero">Ver tratamientos</a>
      </div>

      <p class="hero-trust">
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#19C771"><path d="M7 0C3.13 0 0 3.13 0 7s3.13 7 7 7 7-3.13 7-7S10.87 0 7 0zm-1.4 10.15L2.45 7l.98-.98 2.17 2.17 4.97-4.96.98.98-5.95 5.94z"/></svg>
          Sin compromiso
        </span>
        <span class="trust-sep">·</span>
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#19C771"><path d="M7 0C3.13 0 0 3.13 0 7s3.13 7 7 7 7-3.13 7-7S10.87 0 7 0zm-1.4 10.15L2.45 7l.98-.98 2.17 2.17 4.97-4.96.98.98-5.95 5.94z"/></svg>
          Atención personalizada
        </span>
        <span class="trust-sep">·</span>
        <span class="trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#19C771"><path d="M7 0C3.13 0 0 3.13 0 7s3.13 7 7 7 7-3.13 7-7S10.87 0 7 0zm-1.4 10.15L2.45 7l.98-.98 2.17 2.17 4.97-4.96.98.98-5.95 5.94z"/></svg>
          Resultados garantizados
        </span>
      </p>
    </div>

    <!-- RIGHT: Visual -->
    <div class="hero-visual" aria-hidden="true">
      <div class="vis-frame">
        <div class="vis-inner">
          <!-- Abstract brand art -->
          <div class="vis-art">
            <div class="art-circle art-c1"></div>
            <div class="art-circle art-c2"></div>
            <div class="art-circle art-c3"></div>
            <div class="art-lines">
              <div class="art-line al-1"></div>
              <div class="art-line al-2"></div>
            </div>
            <div class="art-logo-text">
              <span class="alt-clinica">CLÍNICA</span>
              <span class="alt-esmera">ESMERA</span>
              <span class="alt-tagline">Belleza · Ciencia · Resultados</span>
            </div>
          </div>
        </div>

        <!-- Floating social proof tags -->
        <div class="ftag ftag-1">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="#19C771"><path d="M7.5 0C3.36 0 0 3.36 0 7.5S3.36 15 7.5 15 15 11.64 15 7.5 11.64 0 7.5 0zm-1.5 10.78L2.2 6.98l1.06-1.06 2.74 2.74 5.74-5.74 1.06 1.07L6 10.78z"/></svg>
          Tecnología certificada
        </div>
        <div class="ftag ftag-2">
          ⭐⭐⭐⭐⭐ &nbsp;4.9 · +500 reseñas
        </div>
        <div class="ftag ftag-3">
          ✦ +5.000 procedimientos realizados
        </div>

        <!-- Decoration border -->
        <div class="vis-deco"></div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="sh-line"></div>
    <span>Explora</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--dark);
    position: relative; overflow: hidden;
    display: flex; align-items: center;
    padding-top: 72px;
  }

  /* Background decorations */
  .bg-deco { position: absolute; inset: 0; pointer-events: none; }
  .bg-glow {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: 0.12;
  }
  .bg-glow-1 {
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--gold), transparent 70%);
    top: -250px; right: -150px;
  }
  .bg-glow-2 {
    width: 450px; height: 450px;
    background: radial-gradient(circle, var(--green), transparent 70%);
    bottom: -100px; left: 5%; opacity: 0.08;
  }
  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(213,192,57,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(213,192,57,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  /* Layout */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: center;
    padding-top: 80px; padding-bottom: 80px;
    position: relative; z-index: 1;
  }

  /* Live badge */
  .live-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(213,192,57,0.1);
    border: 1px solid rgba(213,192,57,0.28);
    color: var(--gold);
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 8px 18px; border-radius: 50px;
    margin-bottom: 28px;
    animation: pulse 2.5s infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(213,192,57,0.25); }
    50% { box-shadow: 0 0 0 8px rgba(213,192,57,0); }
  }
  .live-dot {
    width: 7px; height: 7px;
    background: var(--gold); border-radius: 50%;
    animation: blink 1.6s infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  /* Heading */
  .hero-h1 {
    font-size: clamp(2.8rem, 5vw, 4.6rem);
    font-weight: 700; color: white;
    line-height: 1.12; margin-bottom: 24px;
  }
  .gold-italic { font-style: italic; color: var(--gold); }

  /* Description */
  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.75; margin-bottom: 32px;
    max-width: 470px;
  }

  /* Offer box */
  .offer-box {
    display: flex; align-items: center; gap: 16px;
    background: rgba(213,192,57,0.07);
    border: 1px solid rgba(213,192,57,0.22);
    border-left: 4px solid var(--gold);
    padding: 16px 20px; border-radius: 14px;
    margin-bottom: 36px; position: relative;
  }
  .offer-star { font-size: 1.4rem; color: var(--gold); flex-shrink: 0; }
  .offer-label {
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.12em; color: var(--gold);
    text-transform: uppercase; margin-bottom: 5px;
  }
  .offer-text { font-size: 0.95rem; color: rgba(255,255,255,0.88); }
  .offer-text strong { color: var(--gold); }
  .offer-badge {
    position: absolute; top: -12px; right: 20px;
    background: var(--gold); color: var(--dark);
    font-size: 0.65rem; font-weight: 800;
    letter-spacing: 0.12em;
    padding: 4px 10px; border-radius: 50px;
  }

  /* Buttons */
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 26px; }
  .btn-hero { padding: 16px 32px; font-size: 1rem; }

  /* Trust bar */
  .hero-trust {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    font-size: 0.82rem; color: rgba(255,255,255,0.45);
  }
  .trust-item { display: flex; align-items: center; gap: 5px; }
  .trust-sep { color: rgba(255,255,255,0.2); }

  /* Visual right side */
  .hero-visual {
    display: flex; justify-content: center; align-items: center;
  }
  .vis-frame { position: relative; width: 100%; max-width: 460px; }

  .vis-inner {
    border-radius: 28px; overflow: hidden;
    aspect-ratio: 4/5;
    background:
      linear-gradient(155deg,
        rgba(213,192,57,0.18) 0%,
        rgba(25,199,113,0.1) 35%,
        rgba(30,30,30,0.9) 100%
      );
    border: 1px solid rgba(213,192,57,0.2);
    position: relative;
  }

  /* Abstract brand art inside visual */
  .vis-art {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .art-circle {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(213,192,57,0.2);
  }
  .art-c1 {
    width: 280px; height: 280px;
    background: radial-gradient(circle at 40% 40%, rgba(213,192,57,0.12), transparent 65%);
    top: 8%; left: 50%; transform: translateX(-50%);
  }
  .art-c2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle, rgba(25,199,113,0.1), transparent 65%);
    top: 12%; left: 50%; transform: translateX(-50%);
    border-color: rgba(25,199,113,0.15);
  }
  .art-c3 {
    width: 90px; height: 90px;
    background: rgba(213,192,57,0.15);
    top: 22%; left: 50%; transform: translateX(-50%);
  }
  .art-lines { position: absolute; bottom: 0; left: 0; right: 0; height: 50%; }
  .art-line {
    position: absolute; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(213,192,57,0.25), transparent);
  }
  .al-1 { width: 70%; left: 15%; bottom: 55%; }
  .al-2 { width: 50%; left: 25%; bottom: 45%; }

  .art-logo-text {
    position: absolute; bottom: 18%;
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    text-align: center;
  }
  .alt-clinica {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem; font-weight: 300;
    letter-spacing: 0.4em; color: rgba(255,255,255,0.3);
    text-transform: uppercase;
  }
  .alt-esmera {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; font-weight: 700;
    color: rgba(255,255,255,0.15);
    letter-spacing: 0.1em;
  }
  .alt-tagline {
    font-size: 0.65rem; font-weight: 400;
    letter-spacing: 0.2em; color: rgba(213,192,57,0.3);
    text-transform: uppercase;
  }

  /* Floating tags */
  .ftag {
    position: absolute;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-radius: 12px; padding: 10px 16px;
    font-size: 0.78rem; font-weight: 600;
    color: var(--dark); box-shadow: 0 6px 24px rgba(0,0,0,0.14);
    display: flex; align-items: center; gap: 7px;
    white-space: nowrap;
  }
  .ftag-1 { top: 18px; right: -18px; }
  .ftag-2 { top: 42%; left: -24px; }
  .ftag-3 {
    bottom: 12%; right: 0;
    background: var(--dark); color: var(--gold);
    border: 1px solid rgba(213,192,57,0.25);
  }

  .vis-deco {
    position: absolute; bottom: -18px; right: -18px;
    width: 180px; height: 180px;
    border: 1.5px solid rgba(213,192,57,0.25);
    border-radius: 24px; z-index: -1;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute; bottom: 28px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    color: rgba(255,255,255,0.3);
    font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  }
  .sh-line {
    width: 1px; height: 44px;
    background: linear-gradient(to bottom, transparent, rgba(213,192,57,0.5));
    animation: sh-anim 2s infinite;
  }
  @keyframes sh-anim {
    0%, 100% { opacity: 0.6; transform: scaleY(1); }
    50% { opacity: 0.25; transform: scaleY(0.6); }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center; gap: 56px;
    }
    .hero-desc, .hero-btns, .hero-trust { margin-left: auto; margin-right: auto; }
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-btns { justify-content: center; }
    .hero-trust { justify-content: center; }
    .hero-visual { order: -1; }
    .vis-frame { max-width: 340px; }
    .ftag-1 { right: -8px; font-size: 0.72rem; }
    .ftag-2 { left: -8px; font-size: 0.72rem; }
    .live-badge { margin-left: auto; margin-right: auto; display: flex; width: fit-content; }
    .offer-box { text-align: left; }
  }

  @media (max-width: 480px) {
    .hero-h1 { font-size: 2.4rem; }
    .vis-frame { max-width: 280px; }
    .ftag-2 { display: none; }
    .btn-hero { width: 100%; justify-content: center; }
    .hero-btns { flex-direction: column; }
  }
</style>
