---
const areas = [
  {
    id: "med-faciales",
    titulo: "Faciales Médico Estéticos",
    desc: "Tratamientos médicos avanzados para el rostro que van más allá de la estética convencional. Nuestros médicos especialistas diseñan protocolos personalizados para resultados visibles y duraderos.",
    tratamientos: [
      { nombre: "Toxina Botulínica", detalle: "Expresión natural, sin congelar" },
      { nombre: "Ácido Hialurónico", detalle: "Relleno y volumen natural" },
      { nombre: "Bioestimuladores", detalle: "Regeneración profunda del colágeno" },
      { nombre: "Mesoterapia Facial", detalle: "Nutrición intensiva personalizada" },
      { nombre: "PRP Facial", detalle: "Plasma rico en plaquetas propio" },
      { nombre: "Peelings Médicos", detalle: "Renovación celular profunda" },
    ],
    tag: "Medicina Estética Facial",
    color: "var(--gold)",
  },
  {
    id: "med-corporales",
    titulo: "Corporales Médico Estéticos",
    desc: "Procedimientos médico-estéticos para el cuerpo que combinan diagnóstico médico, tecnología de vanguardia y protocolos clínicos para transformar tu figura de forma segura.",
    tratamientos: [
      { nombre: "Mesoterapia Corporal", detalle: "Reducción de grasa localizada" },
      { nombre: "Carboxiterapia", detalle: "Oxigenación y reafirmación tisular" },
      { nombre: "Lipolíticos", detalle: "Reducción de volumen sin cirugía" },
      { nombre: "PRP Corporal", detalle: "Regeneración y cicatrización" },
      { nombre: "Vitaminas IV", detalle: "Nutrición intravenosa premium" },
      { nombre: "Bioestimuladores Corporales", detalle: "Firmeza y elasticidad" },
    ],
    tag: "Medicina Estética Corporal",
    color: "var(--green)",
  },
];
---

<section class="medico-section" id="medico-estetico">
  <div class="container">
    <div class="med-header">
      <span class="section-tag">Medicina Estética</span>
      <h2 class="section-title">Ciencia al servicio<br /><em>de tu belleza</em></h2>
      <p class="section-lead">
        Tratamientos médico-estéticos supervisados por profesionales especializados.
        Máxima seguridad, eficacia clínica comprobada y resultados que perduran.
      </p>

      <div class="med-badges">
        <div class="med-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="#19C771"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.8L3.6 8.6l1.1-1.1 2.1 2.1 4.4-4.4 1.1 1.1-5.5 5.5z"/></svg>
          Médicos especializados
        </div>
        <div class="med-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="#19C771"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.8L3.6 8.6l1.1-1.1 2.1 2.1 4.4-4.4 1.1 1.1-5.5 5.5z"/></svg>
          Productos certificados CE
        </div>
        <div class="med-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="#19C771"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.8L3.6 8.6l1.1-1.1 2.1 2.1 4.4-4.4 1.1 1.1-5.5 5.5z"/></svg>
          Consulta previa incluida
        </div>
      </div>
    </div>

    <div class="med-grid">
      {areas.map((area) => (
        <div class="med-card">
          <div class="med-card-tag" style={`border-color: ${area.color}; color: ${area.color};`}>
            {area.tag}
          </div>
          <h3 class="med-card-title">{area.titulo}</h3>
          <p class="med-card-desc">{area.desc}</p>

          <div class="tratamientos-grid">
            {area.tratamientos.map(t => (
              <div class="trat-item">
                <div class="trat-dot" style={`background: ${area.color};`}></div>
                <div>
                  <p class="trat-nombre">{t.nombre}</p>
                  <p class="trat-detalle">{t.detalle}</p>
                </div>
              </div>
            ))}
          </div>

          <a href="#contacto" class="btn btn-dark btn-med">
            Consulta médica gratuita
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2.5 7.5h10M9 4l3.5 3.5L9 11"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Doctor note -->
    <div class="med-note">
      <div class="note-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round">
          <path d="M11 2a9 9 0 100 18A9 9 0 0011 2zM11 7v5l3 3"/>
        </svg>
      </div>
      <p>
        <strong>Todos los tratamientos médicos</strong> incluyen valoración previa con nuestro equipo médico especializado.
        Tu seguridad y los resultados óptimos son nuestra prioridad. Protocolos individualizados para cada paciente.
      </p>
    </div>
  </div>
</section>

<style>
  .medico-section {
    padding: 100px 0;
    background: var(--white);
    position: relative;
  }

  .med-header { margin-bottom: 56px; }

  .section-title em {
    font-style: italic; color: var(--gold);
  }

  .med-badges {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-top: 28px;
  }

  .med-badge {
    display: flex; align-items: center; gap: 7px;
    background: #F0FDF6;
    border: 1px solid rgba(25,199,113,0.25);
    padding: 8px 16px; border-radius: 50px;
    font-size: 0.82rem; font-weight: 600; color: var(--dark);
  }

  .med-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 40px;
  }

  .med-card {
    background: var(--off-white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 40px 36px;
    transition: all var(--transition);
    position: relative; overflow: hidden;
  }

  .med-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--green));
  }

  .med-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: transparent;
  }

  .med-card-tag {
    display: inline-block;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    border: 1.5px solid; border-radius: 50px;
    padding: 5px 14px; margin-bottom: 18px;
  }

  .med-card-title {
    font-family: var(--font-heading);
    font-size: 1.6rem; font-weight: 600;
    color: var(--dark); margin-bottom: 14px;
  }

  .med-card-desc {
    font-size: 0.9rem; color: var(--text-muted);
    line-height: 1.72; margin-bottom: 28px;
  }

  .tratamientos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px; margin-bottom: 32px;
  }

  .trat-item {
    display: flex; align-items: flex-start; gap: 10px;
  }

  .trat-dot {
    width: 8px; height: 8px;
    border-radius: 50%; flex-shrink: 0; margin-top: 5px;
  }

  .trat-nombre {
    font-size: 0.875rem; font-weight: 600; color: var(--dark);
    line-height: 1.3;
  }

  .trat-detalle {
    font-size: 0.78rem; color: var(--text-muted); margin-top: 2px;
  }

  .btn-med { width: 100%; justify-content: center; padding: 15px; }

  .med-note {
    display: flex; align-items: flex-start; gap: 16px;
    background: var(--gold-bg);
    border: 1px solid rgba(213,192,57,0.3);
    border-radius: var(--radius-sm);
    padding: 20px 24px;
  }

  .note-icon {
    width: 44px; height: 44px; flex-shrink: 0;
    background: rgba(213,192,57,0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .med-note p {
    font-size: 0.9rem; color: var(--text-muted); line-height: 1.65;
  }

  .med-note strong { color: var(--dark); }

  @media (max-width: 860px) {
    .med-grid { grid-template-columns: 1fr; }
    .tratamientos-grid { grid-template-columns: 1fr; }
    .medico-section { padding: 72px 0; }
  }

  @media (max-width: 480px) {
    .med-card { padding: 28px 22px; }
  }
</style>
