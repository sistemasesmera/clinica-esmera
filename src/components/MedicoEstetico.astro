---
const areas = [
  {
    num: "I",
    titulo: "Medicina Estética Facial",
    intro: "Tratamientos médicos avanzados para el rostro, supervisados por nuestros especialistas. Protocolos personalizados para resultados visibles y duraderos.",
    tratamientos: [
      { nombre: "Toxina Botulínica",       detalle: "Expresión natural, sin congelar" },
      { nombre: "Ácido Hialurónico",       detalle: "Relleno y volumen natural" },
      { nombre: "Bioestimuladores",        detalle: "Regeneración profunda de colágeno" },
      { nombre: "Mesoterapia Facial",      detalle: "Nutrición intensiva personalizada" },
      { nombre: "PRP Facial",             detalle: "Plasma rico en plaquetas propio" },
      { nombre: "Peelings Médicos",        detalle: "Renovación celular profunda" },
    ],
  },
  {
    num: "II",
    titulo: "Medicina Estética Corporal",
    intro: "Procedimientos médicos para el cuerpo que combinan diagnóstico clínico, tecnología de vanguardia y protocolos avalados para transformar tu figura de forma segura.",
    tratamientos: [
      { nombre: "Mesoterapia Corporal",         detalle: "Reducción de grasa localizada" },
      { nombre: "Carboxiterapia",               detalle: "Oxigenación y reafirmación tisular" },
      { nombre: "Lipolíticos",                  detalle: "Reducción de volumen sin cirugía" },
      { nombre: "PRP Corporal",                 detalle: "Regeneración y cicatrización" },
      { nombre: "Vitaminas IV",                 detalle: "Nutrición intravenosa premium" },
      { nombre: "Bioestimuladores Corporales",  detalle: "Firmeza y elasticidad duradera" },
    ],
  },
];
---

<section class="medico" id="medico-estetico">
  <div class="container">

    <div class="med-header">
      <div class="eyebrow"><span>Medicina Estética</span></div>
      <h2 class="sec-title">Ciencia al servicio<br /><em>de tu belleza</em></h2>
      <p class="sec-lead">
        Tratamientos supervisados por médicos especialistas. Máxima seguridad,
        eficacia clínica comprobada y resultados que perduran.
      </p>

      <div class="med-certifications">
        <span>Médicos certificados</span>
        <span class="cert-sep">·</span>
        <span>Productos con marcado CE</span>
        <span class="cert-sep">·</span>
        <span>Consulta previa incluida</span>
      </div>
    </div>

    <div class="med-grid">
      {areas.map(a => (
        <div class="med-card">
          <div class="med-card-num">{a.num}</div>
          <div class="med-gold-line"></div>
          <h3 class="med-card-title">{a.titulo}</h3>
          <p class="med-card-intro">{a.intro}</p>

          <ul class="med-trats">
            {a.tratamientos.map(t => (
              <li class="trat-row">
                <span class="trat-nombre">{t.nombre}</span>
                <span class="trat-sep-line"></span>
                <span class="trat-detalle">{t.detalle}</span>
              </li>
            ))}
          </ul>

          <a href="#contacto" class="btn btn-solid">
            Consulta médica gratuita
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 6.5h9M8 3l3.5 3.5L8 10"/></svg>
          </a>
        </div>
      ))}
    </div>

    <div class="med-note">
      <span class="note-orn">✦</span>
      <p>
        Todos los tratamientos de medicina estética incluyen valoración previa con nuestro
        equipo médico. Cada protocolo se diseña de forma individual según tus objetivos.
      </p>
    </div>

  </div>
</section>

<style>
  .medico {
    padding: 120px 0;
    background: var(--ivory-mid);
  }

  .med-header { margin-bottom: 64px; }

  .med-certifications {
    display: flex; align-items: center; gap: 12px;
    flex-wrap: wrap; margin-top: 24px;
    font-size: 0.75rem; font-weight: 400;
    letter-spacing: 0.08em; color: var(--text-muted);
  }
  .cert-sep { color: var(--gold); opacity: 0.5; }

  .med-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px; margin-bottom: 40px;
  }

  .med-card {
    background: var(--white);
    padding: 48px 44px;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: var(--radius);
    transition: box-shadow var(--t);
    position: relative;
  }

  .med-card:hover { box-shadow: var(--shadow-mid); }

  .med-card-num {
    font-family: var(--font-display);
    font-style: italic; font-weight: 300;
    font-size: 0.8rem; letter-spacing: 0.15em;
    color: var(--gold); margin-bottom: 14px;
    opacity: 0.8;
  }

  .med-gold-line {
    width: 32px; height: 1px;
    background: var(--gold); opacity: 0.4;
    margin-bottom: 22px;
  }

  .med-card-title {
    font-family: var(--font-display);
    font-size: 1.65rem; font-weight: 400;
    color: var(--dark); margin-bottom: 14px;
  }

  .med-card-intro {
    font-size: 0.875rem; color: var(--text-muted);
    line-height: 1.75; margin-bottom: 32px;
    font-weight: 300;
  }

  /* Treatments list — elegant table style */
  .med-trats {
    list-style: none;
    border-top: 1px solid rgba(0,0,0,0.06);
    margin-bottom: 36px;
  }

  .trat-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .trat-nombre {
    font-size: 0.85rem; font-weight: 500;
    color: var(--dark); white-space: nowrap; flex-shrink: 0;
    letter-spacing: 0.01em;
  }

  .trat-sep-line {
    flex: 1; height: 1px;
    background: repeating-linear-gradient(
      90deg,
      rgba(213,192,57,0.25) 0, rgba(213,192,57,0.25) 3px,
      transparent 3px, transparent 8px
    );
  }

  .trat-detalle {
    font-size: 0.78rem; color: var(--text-muted);
    text-align: right; white-space: nowrap; flex-shrink: 0;
    font-weight: 300;
  }

  /* Note */
  .med-note {
    display: flex; align-items: flex-start; gap: 16px;
    background: var(--ivory);
    border: 1px solid rgba(213,192,57,0.2);
    padding: 20px 28px;
    border-radius: var(--radius);
  }
  .note-orn { color: var(--gold); opacity: 0.6; flex-shrink: 0; font-size: 0.8rem; margin-top: 2px; }
  .med-note p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; font-weight: 300; }

  @media (max-width: 860px) {
    .med-grid { grid-template-columns: 1fr; }
    .med-card { padding: 36px 28px; }
    .medico { padding: 80px 0; }
  }

  @media (max-width: 480px) {
    .trat-row { flex-wrap: wrap; gap: 4px; }
    .trat-sep-line { display: none; }
    .trat-detalle { text-align: left; color: var(--text-muted); }
  }
</style>
