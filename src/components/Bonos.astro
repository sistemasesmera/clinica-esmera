---
const bonos = [
  {
    romano: "I",
    nombre: "Bono Esencial",
    precio: "249",
    sesiones: 3,
    desc: "El punto de partida ideal para descubrir la diferencia Esmera. Tres sesiones de tratamiento estético a medida.",
    incluye: [
      "3 sesiones a elegir — facial o corporal",
      "Consulta inicial personalizada",
      "Protocolo adaptado a tus objetivos",
      "Seguimiento entre sesiones",
      "10% en productos de la clínica",
    ],
    destacado: false,
  },
  {
    romano: "II",
    nombre: "Bono Intensivo",
    precio: "459",
    sesiones: 6,
    desc: "Seis sesiones de alta eficacia, combinando tratamientos faciales y corporales, para resultados visibles y duraderos.",
    incluye: [
      "6 sesiones combinables — facial + corporal",
      "Diagnóstico de piel completo",
      "Protocolo premium personalizado",
      "Acceso a aparatología avanzada",
      "Seguimiento mensual incluido",
      "15% en productos de la clínica",
    ],
    destacado: true,
  },
  {
    romano: "III",
    nombre: "Bono VIP",
    precio: "699",
    sesiones: 10,
    desc: "La experiencia Esmera en su máxima expresión. Diez sesiones de los tratamientos más avanzados con seguimiento exclusivo.",
    incluye: [
      "10 sesiones premium a medida",
      "Evaluación médico-estética completa",
      "Protocolo médico-estético combinado",
      "Acceso ilimitado a aparatología",
      "Seguimiento semanal personalizado",
      "20% en productos de la clínica",
      "Atención prioritaria garantizada",
    ],
    destacado: false,
  },
];
---

<section class="bonos" id="bonos">
  <div class="container">
    <div class="bonos-hd">
      <div class="eyebrow"><span>Bonos &amp; Packs</span></div>
      <h2 class="sec-title">Invierte en ti.<br /><em>Ahorra en cada sesión.</em></h2>
      <p class="sec-lead">
        Nuestros bonos están diseñados para que obtengas los mejores resultados
        al precio más ventajoso. Cuanto mayor el compromiso, mayor el ahorro.
      </p>
    </div>

    <div class="bonos-grid">
      {bonos.map(b => (
        <article class={`bono-card ${b.destacado ? 'bono-feat' : ''}`}>
          {b.destacado && (
            <div class="feat-label">Más solicitado</div>
          )}
          <div class="bono-romano">{b.romano}</div>
          <div class="bono-gold-rule"></div>
          <h3 class="bono-nombre">{b.nombre}</h3>
          <p class="bono-desc">{b.desc}</p>

          <div class="bono-precio">
            <span class="bp-desde">desde</span>
            <span class="bp-num">{b.precio}€</span>
            <span class="bp-unit">/ {b.sesiones} sesiones</span>
          </div>

          <ul class="bono-lista">
            {b.incluye.map(item => (
              <li>
                <span class="bono-tick">—</span>
                {item}
              </li>
            ))}
          </ul>

          <a href="#contacto" class={`btn ${b.destacado ? 'btn-gold' : 'btn-ghost-dark'} bono-btn`}>
            {b.destacado ? 'Contratar ahora' : 'Solicitar información'}
          </a>
        </article>
      ))}
    </div>

    <p class="bonos-custom">
      <span class="bc-orn">✦</span>
      ¿Buscas algo a medida? Diseñamos bonos personalizados según tus objetivos y presupuesto.
      <a href="#contacto" class="bc-link">Consúltanos →</a>
    </p>
  </div>
</section>

<style>
  .bonos {
    padding: 120px 0;
    background: var(--ivory-mid);
  }

  .bonos-hd { margin-bottom: 72px; }

  .bonos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    overflow: visible;
    margin-bottom: 36px;
    position: relative;
  }

  .bono-card {
    background: var(--white);
    padding: 44px 36px 40px;
    display: flex; flex-direction: column;
    position: relative;
    transition: background var(--t);
  }
  .bono-card:hover { background: var(--ivory); }

  /* Featured */
  .bono-feat {
    background: var(--dark) !important;
    z-index: 2;
    margin: -1px;
    box-shadow: var(--shadow-mid);
    border-radius: var(--radius);
  }
  .bono-feat:hover { background: var(--dark) !important; }

  .feat-label {
    position: absolute; top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--dark);
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    padding: 5px 18px; border-radius: 2px;
    white-space: nowrap;
  }

  .bono-romano {
    font-family: var(--font-display);
    font-style: italic; font-weight: 300;
    font-size: 0.9rem; color: var(--gold);
    letter-spacing: 0.1em; margin-bottom: 14px;
    opacity: 0.8;
  }

  .bono-gold-rule {
    width: 28px; height: 1px;
    background: var(--gold); opacity: 0.35;
    margin-bottom: 20px;
  }

  .bono-nombre {
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: 400;
    color: var(--dark); margin-bottom: 12px;
  }
  .bono-feat .bono-nombre { color: rgba(255,255,255,0.9); }

  .bono-desc {
    font-size: 0.83rem; color: var(--text-muted);
    line-height: 1.7; margin-bottom: 24px; font-weight: 300;
  }
  .bono-feat .bono-desc { color: rgba(255,255,255,0.5); }

  .bono-precio {
    display: flex; align-items: baseline; gap: 5px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .bono-feat .bono-precio { border-color: rgba(255,255,255,0.08); }

  .bp-desde { font-size: 0.72rem; color: var(--stone-light); font-weight: 300; }
  .bp-num {
    font-family: var(--font-display);
    font-size: 2.6rem; font-weight: 300; font-style: italic;
    color: var(--gold); line-height: 1; letter-spacing: -0.02em;
  }
  .bp-unit { font-size: 0.78rem; color: var(--stone-light); font-weight: 300; margin-left: 2px; }
  .bono-feat .bp-unit { color: rgba(255,255,255,0.35); }

  .bono-lista {
    list-style: none; flex: 1;
    display: flex; flex-direction: column; gap: 10px;
    margin-bottom: 32px;
  }

  .bono-lista li {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 0.82rem; color: var(--text-soft); font-weight: 300; line-height: 1.4;
  }
  .bono-feat .bono-lista li { color: rgba(255,255,255,0.6); }

  .bono-tick { color: var(--gold); opacity: 0.7; flex-shrink: 0; font-size: 0.75rem; margin-top: 1px; }

  .bono-btn { width: 100%; justify-content: center; margin-top: auto; }

  /* Custom note */
  .bonos-custom {
    display: flex; align-items: center; gap: 10px;
    justify-content: center; flex-wrap: wrap;
    font-size: 0.83rem; color: var(--text-muted); font-weight: 300;
    text-align: center;
  }
  .bc-orn { color: var(--gold); opacity: 0.5; }
  .bc-link {
    color: var(--dark); font-weight: 500;
    border-bottom: 1px solid rgba(213,192,57,0.5);
    padding-bottom: 1px; transition: all 0.2s;
  }
  .bc-link:hover { color: var(--gold-warm); border-color: var(--gold); }

  @media (max-width: 860px) {
    .bonos-grid {
      grid-template-columns: 1fr;
      max-width: 440px; margin-left: auto; margin-right: auto;
    }
    .bono-feat { margin: 0; }
    .bonos { padding: 80px 0; }
  }

  @media (max-width: 480px) {
    .bono-card { padding: 32px 24px; }
  }
</style>
