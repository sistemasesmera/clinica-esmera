---
const valores = [
  {
    icono: "◎",
    titulo: "Resultados reales",
    desc: "Medimos nuestro éxito por los resultados de cada cliente. Sin promesas vacías, solo transformaciones comprobadas.",
  },
  {
    icono: "✦",
    titulo: "Tecnología certificada",
    desc: "Todos nuestros equipos son de grado médico con certificación CE y avalados por estudios clínicos internacionales.",
  },
  {
    icono: "❋",
    titulo: "Equipo especializado",
    desc: "Médicos estéticos, esteticistas tituladas y profesionales en continua formación con las últimas técnicas del sector.",
  },
  {
    icono: "◈",
    titulo: "Trato personalizado",
    desc: "Cada persona es única. Diseñamos protocolos exclusivos adaptados a tus objetivos, tu piel y tu estilo de vida.",
  },
];

const reviews = [
  {
    nombre: "María L.",
    texto: "Llevo tres meses con el protocolo de medicina estética y los resultados son increíbles. El equipo es muy profesional y el trato, excelente.",
    stars: 5,
    tratamiento: "Medicina Estética Facial",
  },
  {
    nombre: "Carlos M.",
    texto: "Vine por la criolipólisis con dudas y salí encantado. Los resultados empezaron a verse desde el mes. 100% recomendable.",
    stars: 5,
    tratamiento: "Criolipólisis",
  },
  {
    nombre: "Ana P.",
    texto: "La micropigmentación de cejas me cambió la vida. Quedaron naturalísimas. El proceso fue muy cómodo y el resultado, perfecto.",
    stars: 5,
    tratamiento: "Micropigmentación",
  },
];
---

<section class="nosotros-section" id="nosotros">
  <div class="container">
    <!-- About block -->
    <div class="nosotros-grid">
      <div class="nos-visual" aria-hidden="true">
        <div class="nos-img-frame">
          <div class="nos-img-inner">
            <div class="nos-art">
              <div class="nos-circle nc1"></div>
              <div class="nos-circle nc2"></div>
              <div class="nos-logo-over">
                <span class="nlo-clinica">CLÍNICA</span>
                <span class="nlo-esmera">ESMERA</span>
                <div class="nlo-line"></div>
                <span class="nlo-since">Desde 2014</span>
              </div>
            </div>
          </div>
          <div class="nos-img-deco"></div>
          <div class="nos-badge">
            <div class="nos-badge-num">+10</div>
            <div class="nos-badge-text">años<br />de experiencia</div>
          </div>
        </div>
      </div>

      <div class="nos-content">
        <span class="section-tag">Quiénes Somos</span>
        <h2 class="section-title">
          Más de una década<br />
          <em>transformando vidas</em>
        </h2>
        <p class="nos-texto">
          Clínica Esmera nació en 2014 con una misión clara: democratizar la estética y la
          medicina estética de alta calidad para que cualquier persona pueda acceder a
          los mejores tratamientos con total confianza y seguridad.
        </p>
        <p class="nos-texto">
          Hoy somos un referente en el sector, con un equipo de más de 15 profesionales
          entre médicos estéticos, esteticistas especializadas y personal sanitario. Nuestro
          compromiso es con los resultados reales, la máxima seguridad y la experiencia
          más cuidada que puedas encontrar.
        </p>

        <div class="nos-valores-grid">
          {valores.map(v => (
            <div class="nos-valor">
              <div class="nv-icon">{v.icono}</div>
              <div>
                <p class="nv-titulo">{v.titulo}</p>
                <p class="nv-desc">{v.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <a href="#contacto" class="btn btn-dark">
          Conoce a nuestro equipo
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2.5 7.5h10M9 4l3.5 3.5L9 11"/></svg>
        </a>
      </div>
    </div>

    <!-- Reviews -->
    <div class="reviews-block">
      <div class="reviews-header">
        <h3 class="reviews-title">Lo que dicen nuestros clientes</h3>
        <div class="reviews-rating">
          <div class="stars">★★★★★</div>
          <span>4.9 de 5 · +500 reseñas verificadas</span>
        </div>
      </div>

      <div class="reviews-grid">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">
              {"★".repeat(r.stars)}
            </div>
            <p class="review-text">"{r.texto}"</p>
            <div class="review-footer">
              <div class="review-avatar">
                {r.nombre.charAt(0)}
              </div>
              <div>
                <p class="review-name">{r.nombre}</p>
                <p class="review-trat">{r.tratamiento}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CTA final contact section -->
<section class="cta-section" id="contacto">
  <div class="container cta-inner">
    <div class="cta-text">
      <span class="section-tag" style="background: rgba(213,192,57,0.15); border-color: var(--gold); color: var(--gold);">
        Pide tu cita
      </span>
      <h2 class="cta-title">¿Lista para<br /><em>tu transformación?</em></h2>
      <p class="cta-desc">
        Da el primer paso. Agenda tu consulta gratuita y descubre qué tratamiento
        es el más adecuado para ti. Sin compromiso, sin letra pequeña.
      </p>
      <ul class="cta-features">
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.4L3.2 7.8l1.1-1.1 2.5 2.5 4.9-4.9 1.1 1.1-6 6z"/></svg>
          Primera consulta 100% gratuita
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.4L3.2 7.8l1.1-1.1 2.5 2.5 4.9-4.9 1.1 1.1-6 6z"/></svg>
          Diagnóstico personalizado
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.4L3.2 7.8l1.1-1.1 2.5 2.5 4.9-4.9 1.1 1.1-6 6z"/></svg>
          Sin compromiso de compra
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8S12.42 0 8 0zm-1.2 11.4L3.2 7.8l1.1-1.1 2.5 2.5 4.9-4.9 1.1 1.1-6 6z"/></svg>
          Oferta de bienvenida activa
        </li>
      </ul>
    </div>

    <div class="cta-form-wrap">
      <div class="cta-form">
        <h3 class="form-title">Reserva tu consulta</h3>
        <p class="form-subtitle">Gratuita · Sin compromiso · En 24h nos ponemos en contacto</p>
        <form>
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="apellidos">Apellidos *</label>
              <input type="text" id="apellidos" name="apellidos" placeholder="Tus apellidos" required />
            </div>
          </div>
          <div class="form-group">
            <label for="telefono">Teléfono *</label>
            <input type="tel" id="telefono" name="telefono" placeholder="Tu número de teléfono" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@email.com" />
          </div>
          <div class="form-group">
            <label for="interes">¿Qué te interesa?</label>
            <select id="interes" name="interes">
              <option value="">Selecciona una opción</option>
              <option>Tratamientos Estéticos Faciales</option>
              <option>Tratamientos Estéticos Corporales</option>
              <option>Micropigmentación</option>
              <option>Masajes</option>
              <option>Medicina Estética Facial</option>
              <option>Medicina Estética Corporal</option>
              <option>Aparatología</option>
              <option>Bonos y Packs</option>
              <option>No lo sé aún, necesito asesoramiento</option>
            </select>
          </div>
          <button type="submit" class="btn btn-gold form-submit">
            Solicitar cita gratuita
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </button>
          <p class="form-privacy">
            Al enviar este formulario aceptas nuestra
            <a href="#">política de privacidad</a>.
            Tus datos están seguros con nosotros.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  /* Nosotros */
  .nosotros-section {
    padding: 100px 0 0;
    background: var(--off-white);
  }

  .nosotros-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px; align-items: center;
    margin-bottom: 80px;
  }

  /* Visual */
  .nos-visual { display: flex; justify-content: center; }

  .nos-img-frame { position: relative; width: 100%; max-width: 440px; }

  .nos-img-inner {
    border-radius: 28px; overflow: hidden;
    aspect-ratio: 4/5;
    background: linear-gradient(145deg, rgba(213,192,57,0.12), rgba(25,199,113,0.07), rgba(48,48,48,0.85));
    border: 1px solid rgba(213,192,57,0.18);
    position: relative;
  }

  .nos-art {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }

  .nos-circle {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(213,192,57,0.2);
  }
  .nc1 {
    width: 300px; height: 300px;
    top: 5%; left: 50%; transform: translateX(-50%);
    background: radial-gradient(circle at 40% 40%, rgba(213,192,57,0.1), transparent 65%);
  }
  .nc2 {
    width: 180px; height: 180px;
    top: 15%; left: 50%; transform: translateX(-50%);
    border-color: rgba(25,199,113,0.12);
    background: radial-gradient(circle, rgba(25,199,113,0.08), transparent 65%);
  }

  .nos-logo-over {
    display: flex; flex-direction: column;
    align-items: center; gap: 6px;
    position: absolute; bottom: 22%;
  }
  .nlo-clinica {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem; font-weight: 300;
    letter-spacing: 0.45em; color: rgba(255,255,255,0.25);
    text-transform: uppercase;
  }
  .nlo-esmera {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem; font-weight: 700;
    color: rgba(255,255,255,0.12); letter-spacing: 0.08em;
  }
  .nlo-line {
    width: 48px; height: 1px;
    background: rgba(213,192,57,0.3);
  }
  .nlo-since {
    font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.2em; color: rgba(213,192,57,0.4);
    text-transform: uppercase;
  }

  .nos-img-deco {
    position: absolute; bottom: -16px; left: -16px;
    width: 160px; height: 160px;
    border: 1.5px solid rgba(213,192,57,0.2);
    border-radius: 20px; z-index: -1;
  }

  .nos-badge {
    position: absolute; top: 24px; right: -20px;
    background: var(--gold);
    border-radius: 14px; padding: 14px 18px;
    text-align: center;
    box-shadow: 0 6px 24px rgba(213,192,57,0.35);
  }
  .nos-badge-num {
    font-family: var(--font-heading);
    font-size: 1.8rem; font-weight: 700;
    color: var(--dark); line-height: 1;
  }
  .nos-badge-text {
    font-size: 0.7rem; font-weight: 600;
    color: var(--dark-soft); line-height: 1.3; margin-top: 3px;
  }

  /* Content */
  .nos-content {}

  .section-title em { font-style: italic; color: var(--gold); }

  .nos-texto {
    font-size: 0.95rem; color: var(--text-muted);
    line-height: 1.75; margin-bottom: 16px;
  }

  .nos-valores-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; margin: 28px 0 36px;
  }

  .nos-valor {
    display: flex; gap: 12px; align-items: flex-start;
  }
  .nv-icon {
    font-size: 1.1rem; color: var(--gold);
    flex-shrink: 0; margin-top: 2px;
  }
  .nv-titulo { font-weight: 700; font-size: 0.9rem; color: var(--dark); margin-bottom: 4px; }
  .nv-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.55; }

  /* Reviews */
  .reviews-block {
    padding: 56px 0;
    border-top: 1px solid var(--gray-200);
  }

  .reviews-header {
    display: flex; align-items: center;
    justify-content: space-between; margin-bottom: 40px;
    flex-wrap: wrap; gap: 16px;
  }

  .reviews-title {
    font-family: var(--font-heading);
    font-size: 1.6rem; font-weight: 600; color: var(--dark);
  }

  .reviews-rating {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.875rem; color: var(--text-muted); font-weight: 500;
  }

  .stars { color: var(--gold); font-size: 1.1rem; letter-spacing: 2px; }

  .reviews-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .review-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 28px 24px;
    transition: all var(--transition);
  }

  .review-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: rgba(213,192,57,0.2);
  }

  .review-stars { color: var(--gold); font-size: 0.9rem; margin-bottom: 14px; }

  .review-text {
    font-size: 0.88rem; color: var(--text-muted);
    line-height: 1.7; margin-bottom: 20px;
    font-style: italic;
  }

  .review-footer { display: flex; align-items: center; gap: 12px; }

  .review-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--gold); color: var(--dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.9rem; flex-shrink: 0;
  }

  .review-name { font-weight: 700; font-size: 0.875rem; color: var(--dark); }
  .review-trat { font-size: 0.75rem; color: var(--text-muted); }

  /* CTA Section */
  .cta-section {
    padding: 100px 0;
    background: var(--dark);
    position: relative; overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 0% 50%, rgba(213,192,57,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 100% 0%, rgba(25,199,113,0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 72px; align-items: start;
    position: relative; z-index: 1;
  }

  .cta-section .section-tag { margin-bottom: 18px; }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: white; margin-bottom: 20px;
  }
  .cta-title em { font-style: italic; color: var(--gold); }

  .cta-desc {
    font-size: 1rem; color: rgba(255,255,255,0.65);
    line-height: 1.72; margin-bottom: 32px;
  }

  .cta-features {
    list-style: none;
    display: flex; flex-direction: column; gap: 12px;
  }

  .cta-features li {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.9rem; color: rgba(255,255,255,0.8); font-weight: 500;
  }

  /* Form */
  .cta-form-wrap { display: flex; }

  .cta-form {
    background: white;
    border-radius: var(--radius);
    padding: 40px 36px;
    width: 100%;
  }

  .form-title {
    font-family: var(--font-heading);
    font-size: 1.5rem; font-weight: 600;
    color: var(--dark); margin-bottom: 6px;
  }

  .form-subtitle {
    font-size: 0.82rem; color: var(--text-muted);
    margin-bottom: 28px;
  }

  .form-row {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .form-group {
    display: flex; flex-direction: column; gap: 6px;
    margin-bottom: 14px;
  }

  .form-group label {
    font-size: 0.82rem; font-weight: 600; color: var(--dark);
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem; color: var(--text);
    transition: border-color 0.2s;
    background: var(--off-white);
    outline: none;
    appearance: none;
  }

  .form-group input:focus,
  .form-group select:focus {
    border-color: var(--gold);
    background: var(--white);
  }

  .form-group input::placeholder { color: #bbb; }

  .form-submit {
    width: 100%; justify-content: center;
    padding: 15px; font-size: 1rem; margin-top: 4px;
  }

  .form-privacy {
    font-size: 0.75rem; color: var(--text-muted);
    text-align: center; margin-top: 12px; line-height: 1.5;
  }

  .form-privacy a {
    color: var(--dark); text-decoration: underline;
    text-decoration-color: rgba(213,192,57,0.5);
  }

  /* Responsive */
  @media (max-width: 960px) {
    .nosotros-grid { grid-template-columns: 1fr; gap: 48px; }
    .nos-visual { order: -1; }
    .nos-img-frame { max-width: 380px; }
    .reviews-grid { grid-template-columns: 1fr; max-width: 480px; }
    .cta-inner { grid-template-columns: 1fr; gap: 48px; }
    .nosotros-section { padding: 72px 0 0; }
    .cta-section { padding: 72px 0; }
  }

  @media (max-width: 600px) {
    .nos-valores-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .cta-form { padding: 28px 20px; }
    .nos-badge { right: 0; }
  }
</style>
