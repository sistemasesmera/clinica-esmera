---
const servicios = [
  {
    num: "01",
    titulo: "Faciales",
    desc: "Protocolos de limpieza profunda, hidratación intensiva, peeling y tratamientos antiedad adaptados a la morfología y necesidades de cada piel.",
    items: ["Limpieza facial profunda", "Hidratación intensiva", "Peeling químico", "Tratamiento antiedad", "Microdermoabrasión"],
  },
  {
    num: "02",
    titulo: "Corporales",
    desc: "Tratamientos reductores, modeladores y reafirmantes que cuidan tu cuerpo con técnicas manuales y activos de primera calidad.",
    items: ["Masaje modelador", "Tratamiento reductor", "Envoltura corporal", "Exfoliación integral", "Anticelulitis"],
  },
  {
    num: "03",
    titulo: "Micropigmentación",
    desc: "Definición permanente de cejas, labios y eyeliner con pigmentos de alta calidad y técnicas que respetan la anatomía de cada rostro.",
    items: ["Micropigmentación de cejas", "Micropigmentación labial", "Eyeliner permanente", "Sombreado y degradado", "Retoques incluidos"],
  },
  {
    num: "04",
    titulo: "Masajes",
    desc: "Rituales de bienestar que combinan técnicas terapéuticas y de relajación para recuperar el equilibrio físico y mental.",
    items: ["Drenaje linfático manual", "Masaje relajante", "Masaje deportivo", "Piedras calientes", "Reflexología podal"],
  },
];
---

<section class="estetico" id="estetico">
  <div class="container">
    <div class="section-hd">
      <div class="eyebrow"><span>Tratamientos Estéticos</span></div>
      <h2 class="sec-title">Estética que<br /><em>transforma</em></h2>
      <p class="sec-lead">
        Una gama completa de tratamientos estéticos diseñados para realzar
        tu belleza natural con técnicas probadas y productos de máxima calidad.
      </p>
    </div>

    <div class="svc-grid">
      {servicios.map(s => (
        <article class="svc-card">
          <div class="svc-num">{s.num}</div>
          <div class="svc-divider"></div>
          <h3 class="svc-title">{s.titulo}</h3>
          <p class="svc-desc">{s.desc}</p>
          <ul class="svc-list">
            {s.items.map(item => (
              <li>
                <span class="dot">—</span>
                {item}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="svc-link">
            Reservar cita
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .estetico {
    padding: 120px 0;
    background: var(--ivory);
  }

  .section-hd {
    margin-bottom: 72px;
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .svc-card {
    background: var(--white);
    padding: 40px 32px 36px;
    display: flex; flex-direction: column;
    transition: background var(--t);
  }

  .svc-card:hover { background: var(--ivory-mid); }

  .svc-num {
    font-family: var(--font-display);
    font-size: 0.75rem; font-weight: 300; font-style: italic;
    color: var(--gold); letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .svc-divider {
    width: 28px; height: 1px;
    background: var(--gold); opacity: 0.4;
    margin-bottom: 20px;
  }

  .svc-title {
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: 400;
    color: var(--dark); margin-bottom: 14px;
    letter-spacing: 0.01em;
  }

  .svc-desc {
    font-size: 0.85rem; color: var(--text-muted);
    line-height: 1.75; margin-bottom: 24px;
    font-weight: 300;
  }

  .svc-list {
    list-style: none; flex: 1;
    display: flex; flex-direction: column; gap: 8px;
    margin-bottom: 28px;
  }

  .svc-list li {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.8rem; color: var(--text-soft);
    font-weight: 400; letter-spacing: 0.02em;
  }

  .dot {
    color: var(--gold); font-size: 0.8rem; flex-shrink: 0;
    opacity: 0.7;
  }

  .svc-link {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--dark);
    border-bottom: 1px solid rgba(213,192,57,0.5);
    padding-bottom: 3px;
    width: fit-content;
    transition: all 0.25s;
  }

  .svc-link:hover { color: var(--gold-warm); border-color: var(--gold); gap: 11px; }

  @media (max-width: 960px) {
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .svc-grid { grid-template-columns: 1fr; }
    .estetico { padding: 80px 0; }
    .svc-card { padding: 32px 24px; }
  }
</style>
