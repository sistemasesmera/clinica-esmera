---
const equipos = [
  {
    num: "01",
    nombre: "Radiofrecuencia",
    indicacion: "Tensado · Antiedad · Reafirmación",
    desc: "Estimula la producción de colágeno y elastina para tensar, rejuvenecer y reafirmar la piel de rostro y cuerpo de forma no invasiva y progresiva.",
    beneficios: ["Tensado de piel flácida", "Reducción de arrugas", "Remodelación facial y corporal"],
  },
  {
    num: "02",
    nombre: "HIFU Ultrafocal",
    indicacion: "Lifting · Cuello · Sin cirugía",
    desc: "Ultrasonidos de alta intensidad que actúan en capas profundas. El tratamiento más eficaz para el lifting sin bisturí con resultados de hasta 18 meses.",
    beneficios: ["Lifting facial sin cirugía", "Efecto duradero hasta 18 meses", "Una sola sesión"],
  },
  {
    num: "03",
    nombre: "Criolipólisis",
    indicacion: "Abdomen · Flancos · Muslos",
    desc: "Eliminación selectiva y definitiva de grasa localizada mediante frío controlado. Sin cirugía, sin anestesia, con resultados permanentes.",
    beneficios: ["Grasa localizada permanente", "Sin tiempo de recuperación", "Sesión de 60 minutos"],
  },
  {
    num: "04",
    nombre: "Presoterapia",
    indicacion: "Retención · Celulitis · Circulación",
    desc: "Drenaje linfático mecánico de precisión que elimina toxinas, reduce la retención de líquidos y mejora la circulación y el aspecto de la piel.",
    beneficios: ["Drenaje linfático profundo", "Reducción de retención", "Piernas ligeras"],
  },
  {
    num: "05",
    nombre: "Láser Depilatorio",
    indicacion: "Depilación · Todo tipo de piel",
    desc: "Láser de diodo de última generación para una piel libre de vello de forma permanente. Apto para todo tipo de pieles, rápido e indoloro.",
    beneficios: ["Reducción permanente del vello", "Apto piel morena y oscura", "Desde 6 sesiones"],
  },
  {
    num: "06",
    nombre: "Luz Pulsada IPL",
    indicacion: "Manchas · Rojeces · Vascular",
    desc: "Fototerapia de amplio espectro para tratar manchas, rojeces y fotoenvejecimiento con precisión clínica y sin tiempo de recuperación significativo.",
    beneficios: ["Manchas y melasma", "Rosácea y cuperosis", "Fotoenvejecimiento"],
  },
  {
    num: "07",
    nombre: "Drenaje Linfático",
    indicacion: "Post-operatorio · Edemas · Detox",
    desc: "Presoterapia secuencial combinada con técnica manual para el drenaje más completo del mercado. Fundamental en recuperaciones postoperatorias.",
    beneficios: ["Post-operatorio y edemas", "Detox corporal completo", "Efecto inmediato"],
  },
];
---

<section class="aparat" id="aparatologia">
  <div class="container">

    <div class="aparat-hd">
      <div class="eyebrow"><span>Aparatología Avanzada</span></div>
      <h2 class="sec-title">Tecnología de<br /><em>vanguardia</em></h2>
      <p class="sec-lead">
        Equipos certificados de grado médico combinados con el conocimiento
        de nuestros especialistas para resultados que se ven y se sienten.
      </p>
    </div>

    <div class="aparat-list">
      {equipos.map((e, i) => (
        <article class="aparat-row">
          <div class="ar-num">{e.num}</div>
          <div class="ar-main">
            <div class="ar-top">
              <h3 class="ar-nombre">{e.nombre}</h3>
              <span class="ar-ind">{e.indicacion}</span>
            </div>
            <p class="ar-desc">{e.desc}</p>
          </div>
          <ul class="ar-beneficios">
            {e.beneficios.map(b => (
              <li>
                <span class="ar-dot">—</span>{b}
              </li>
            ))}
          </ul>
          <a href="#contacto" class="ar-cta">
            Consultar
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 5.5h7M6 2.5l2.5 3L6 8.5"/></svg>
          </a>
        </article>
      ))}
    </div>

    <div class="aparat-footer">
      <div class="af-text">
        <p class="af-question">¿No sabes qué tratamiento es el más adecuado para ti?</p>
        <p class="af-sub">Nuestros especialistas realizan una valoración personalizada sin compromiso.</p>
      </div>
      <a href="#contacto" class="btn btn-gold">Valoración gratuita</a>
    </div>

  </div>
</section>

<style>
  .aparat {
    padding: 120px 0;
    background: var(--ivory);
  }

  .aparat-hd { margin-bottom: 64px; }

  /* List layout — more editorial than cards */
  .aparat-list {
    border-top: 1px solid rgba(0,0,0,0.07);
    margin-bottom: 64px;
  }

  .aparat-row {
    display: grid;
    grid-template-columns: 56px 1fr 200px 100px;
    gap: 28px; align-items: start;
    padding: 28px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: background var(--t);
  }

  .aparat-row:hover { background: var(--ivory-mid); }

  /* Padding hack for hover bg without margin issues */
  .aparat-row { margin: 0 -16px; padding-left: 16px; padding-right: 16px; }

  .ar-num {
    font-family: var(--font-display);
    font-style: italic; font-weight: 300;
    font-size: 0.75rem; color: var(--gold);
    letter-spacing: 0.1em; padding-top: 4px; opacity: 0.8;
  }

  .ar-top {
    display: flex; align-items: baseline;
    gap: 16px; margin-bottom: 10px; flex-wrap: wrap;
  }

  .ar-nombre {
    font-family: var(--font-display);
    font-size: 1.3rem; font-weight: 400;
    color: var(--dark); letter-spacing: 0.01em;
  }

  .ar-ind {
    font-size: 0.68rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--text-muted);
    font-weight: 400;
  }

  .ar-desc {
    font-size: 0.83rem; color: var(--text-muted);
    line-height: 1.72; font-weight: 300;
  }

  .ar-beneficios {
    list-style: none;
    display: flex; flex-direction: column; gap: 6px;
    padding-top: 4px;
  }

  .ar-beneficios li {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.78rem; color: var(--text-soft); font-weight: 400;
  }
  .ar-dot { color: var(--gold); opacity: 0.6; font-size: 0.75rem; flex-shrink: 0; }

  .ar-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--dark);
    border-bottom: 1px solid rgba(213,192,57,0.4);
    padding-bottom: 3px; width: fit-content;
    transition: all 0.25s; padding-top: 4px;
  }
  .ar-cta:hover { color: var(--gold-warm); border-color: var(--gold); gap: 10px; }

  /* Footer CTA */
  .aparat-footer {
    display: flex; align-items: center;
    justify-content: space-between; gap: 32px;
    padding: 40px 44px;
    background: var(--dark);
    border-radius: var(--radius);
    flex-wrap: wrap;
  }

  .af-question {
    font-family: var(--font-display);
    font-size: 1.25rem; font-weight: 400;
    color: rgba(255,255,255,0.88); margin-bottom: 6px;
  }
  .af-sub { font-size: 0.85rem; color: rgba(255,255,255,0.45); font-weight: 300; }

  /* Responsive */
  @media (max-width: 960px) {
    .aparat-row {
      grid-template-columns: 40px 1fr;
      grid-template-rows: auto auto auto;
    }
    .ar-beneficios { grid-column: 2; }
    .ar-cta { grid-column: 2; }
    .aparat-footer { padding: 28px 24px; flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 540px) {
    .aparat-row { grid-template-columns: 1fr; }
    .ar-num { display: none; }
    .aparat { padding: 80px 0; }
  }
</style>
