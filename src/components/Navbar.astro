---
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="#inicio" class="nav-logo">
      <span class="logo-sub">CLÍNICA</span>
      <span class="logo-main">ESMERA</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="#inicio" class="nl">Inicio</a></li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Estético
          <svg class="chevron" width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l3.5 3.5L9 4"/></svg>
        </button>
        <ul class="dropdown">
          <li><a href="#estetico">Faciales</a></li>
          <li><a href="#estetico">Corporales</a></li>
          <li><a href="#estetico">Micropigmentación</a></li>
          <li><a href="#estetico">Masajes</a></li>
        </ul>
      </li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Médico Estético
          <svg class="chevron" width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l3.5 3.5L9 4"/></svg>
        </button>
        <ul class="dropdown">
          <li><a href="#medico-estetico">Faciales</a></li>
          <li><a href="#medico-estetico">Corporales</a></li>
        </ul>
      </li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Aparatología
          <svg class="chevron" width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l3.5 3.5L9 4"/></svg>
        </button>
        <ul class="dropdown dropdown-wide">
          <li><a href="#aparatologia">Radiofrecuencia</a></li>
          <li><a href="#aparatologia">HIFU Ultrafocal</a></li>
          <li><a href="#aparatologia">Criolipólisis</a></li>
          <li><a href="#aparatologia">Presoterapia</a></li>
          <li><a href="#aparatologia">Láser Depilatorio</a></li>
          <li><a href="#aparatologia">Luz Pulsada IPL</a></li>
          <li><a href="#aparatologia">Drenaje Linfático</a></li>
        </ul>
      </li>

      <li><a href="#bonos" class="nl">Bonos</a></li>
      <li><a href="#nosotros" class="nl">Nosotros</a></li>

      <li class="mobile-cta">
        <a href="#contacto" class="btn btn-gold btn-sm">Pide Cita</a>
      </li>
    </ul>

    <a href="#contacto" class="btn btn-gold btn-cta-nav">Pide Cita</a>

    <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(213,192,57,0.18);
    transition: box-shadow 0.3s;
  }
  .navbar.scrolled { box-shadow: 0 4px 24px rgba(0,0,0,0.1); }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* Logo */
  .nav-logo {
    display: flex; flex-direction: column;
    line-height: 1; flex-shrink: 0; margin-right: 40px;
  }
  .logo-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400; font-size: 0.6rem;
    letter-spacing: 0.35em; color: #999;
    text-transform: uppercase;
  }
  .logo-main {
    font-family: 'Playfair Display', serif;
    font-weight: 700; font-size: 1.45rem;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #303030 40%, #D5C039 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Nav links */
  .nav-links {
    display: flex; align-items: center;
    gap: 2px; list-style: none; margin: 0 auto;
  }

  .nl {
    display: flex; align-items: center; gap: 5px;
    padding: 8px 13px; font-size: 0.88rem; font-weight: 500;
    color: var(--text); border-radius: 8px;
    transition: all 0.2s; cursor: pointer;
    background: none; border: none; font-family: var(--font-body);
    white-space: nowrap;
  }
  .nl:hover { color: var(--gold); background: var(--gold-bg); }

  .chevron { transition: transform 0.25s; flex-shrink: 0; }

  /* Dropdown */
  .has-drop { position: relative; }

  .has-drop:hover .chevron,
  .has-drop[data-open] .chevron { transform: rotate(180deg); }

  .dropdown {
    position: absolute; top: calc(100% + 10px);
    left: 50%; transform: translateX(-50%) translateY(6px);
    min-width: 200px; background: white;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.13);
    border: 1px solid rgba(213,192,57,0.15);
    list-style: none; padding: 8px;
    opacity: 0; pointer-events: none;
    transition: all 0.22s ease;
  }
  .dropdown-wide { min-width: 230px; }

  .has-drop:hover .dropdown,
  .has-drop[data-open] .dropdown {
    opacity: 1; pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown li a {
    display: block; padding: 9px 14px;
    font-size: 0.875rem; color: var(--text);
    border-radius: 8px; transition: all 0.18s;
  }
  .dropdown li a:hover {
    background: var(--gold-bg); color: var(--dark);
    padding-left: 18px;
  }

  /* CTA nav */
  .btn-cta-nav {
    flex-shrink: 0; margin-left: 16px;
    padding: 10px 22px; font-size: 0.875rem;
  }

  .btn-sm { padding: 10px 20px; font-size: 0.875rem; }

  .mobile-cta { display: none; }

  /* Hamburger */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: 6px; margin-left: 12px;
  }
  .hamburger span {
    display: block; width: 24px; height: 2px;
    background: var(--dark); border-radius: 2px;
    transition: all 0.3s ease;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; width: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 960px) {
    .hamburger { display: flex; }
    .btn-cta-nav { display: none; }
    .mobile-cta { display: flex; padding: 8px 0; }

    .nav-links {
      position: fixed; top: 72px; left: 0; right: 0;
      background: white; flex-direction: column;
      align-items: stretch; gap: 0;
      padding: 12px 16px 24px;
      border-bottom: 2px solid var(--gold);
      max-height: calc(100vh - 72px); overflow-y: auto;
      transform: translateY(-10px); opacity: 0;
      pointer-events: none; transition: all 0.28s ease;
      box-shadow: 0 12px 32px rgba(0,0,0,0.1);
    }
    .nav-links.open {
      transform: translateY(0); opacity: 1; pointer-events: all;
    }

    .nl { padding: 12px 14px; font-size: 0.95rem; justify-content: space-between; }

    .dropdown {
      position: static; transform: none;
      opacity: 1; pointer-events: none;
      box-shadow: none; border: none;
      background: var(--gold-bg); border-radius: 10px;
      margin: 4px 0 8px; max-height: 0;
      overflow: hidden; transition: max-height 0.3s ease, padding 0.3s;
      padding: 0 8px;
    }
    .has-drop[data-open] .dropdown {
      pointer-events: all;
      max-height: 400px; padding: 8px;
    }
    .dropdown li a { padding: 10px 14px; font-size: 0.9rem; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger?.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    navLinks?.classList.toggle('open', !open);
  });

  // Dropdown toggles (mobile click, desktop hover handled by CSS)
  document.querySelectorAll<HTMLElement>('.has-drop').forEach(item => {
    const btn = item.querySelector<HTMLButtonElement>('.drop-toggle');
    btn?.addEventListener('click', () => {
      if (window.innerWidth <= 960) {
        const isOpen = item.hasAttribute('data-open');
        // close all others
        document.querySelectorAll<HTMLElement>('.has-drop[data-open]').forEach(el => {
          if (el !== item) el.removeAttribute('data-open');
        });
        item.toggleAttribute('data-open', !isOpen);
      }
    });
  });

  // Close menu on link click
  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      navLinks?.classList.remove('open');
    });
  });
</script>
