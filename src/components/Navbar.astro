<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="#inicio" class="nav-logo">
      <span class="logo-word">Clínica</span>
      <span class="logo-accent">Esmera</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="#inicio" class="nl">Inicio</a></li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Estético
          <svg class="chev" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 3.5l3 3 3-3"/></svg>
        </button>
        <ul class="dropdown">
          <li><a href="#estetico">Faciales</a></li>
          <li><a href="#estetico">Corporales</a></li>
          <li><a href="#estetico">Micropigmentación</a></li>
          <li><a href="#estetico">Masajes</a></li>
        </ul>
      </li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Médico Estético
          <svg class="chev" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 3.5l3 3 3-3"/></svg>
        </button>
        <ul class="dropdown">
          <li><a href="#medico-estetico">Faciales</a></li>
          <li><a href="#medico-estetico">Corporales</a></li>
        </ul>
      </li>

      <li class="has-drop">
        <button class="nl drop-toggle" aria-expanded="false">
          Aparatología
          <svg class="chev" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 3.5l3 3 3-3"/></svg>
        </button>
        <ul class="dropdown">
          <li><a href="#aparatologia">Radiofrecuencia</a></li>
          <li><a href="#aparatologia">HIFU Ultrafocal</a></li>
          <li><a href="#aparatologia">Criolipólisis</a></li>
          <li><a href="#aparatologia">Presoterapia</a></li>
          <li><a href="#aparatologia">Láser Depilatorio</a></li>
          <li><a href="#aparatologia">Luz Pulsada IPL</a></li>
          <li><a href="#aparatologia">Drenaje Linfático</a></li>
        </ul>
      </li>

      <li><a href="#bonos" class="nl">Bonos</a></li>
      <li><a href="#nosotros" class="nl">Nosotros</a></li>

      <li class="mobile-cta">
        <a href="#contacto" class="btn btn-gold">Pide Cita</a>
      </li>
    </ul>

    <a href="#contacto" class="cta-desktop btn btn-gold">Pide Cita</a>

    <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(250, 249, 245, 0.96);
    backdrop-filter: blur(16px);
    transition: box-shadow var(--t);
  }

  .navbar::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(213,192,57,0.35) 30%, rgba(213,192,57,0.35) 70%, transparent 100%);
  }

  .navbar.scrolled { box-shadow: 0 4px 32px rgba(44,44,44,0.07); }

  .nav-inner {
    max-width: 1180px; margin: 0 auto;
    padding: 0 32px; height: 72px;
    display: flex; align-items: center; gap: 0;
  }

  /* Logo */
  .nav-logo {
    display: flex; align-items: baseline; gap: 5px;
    flex-shrink: 0; margin-right: 48px;
  }
  .logo-word {
    font-family: var(--font-body);
    font-weight: 300; font-size: 0.82rem;
    letter-spacing: 0.15em; color: var(--stone);
    text-transform: uppercase;
  }
  .logo-accent {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.55rem; font-weight: 400;
    color: var(--dark); letter-spacing: 0.04em;
  }

  /* Links */
  .nav-links {
    display: flex; align-items: center;
    gap: 0; list-style: none; margin: 0 auto;
  }

  .nl {
    display: flex; align-items: center; gap: 5px;
    padding: 8px 14px;
    font-size: 0.78rem; font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--text-soft);
    background: none; border: none;
    font-family: var(--font-body);
    cursor: pointer; white-space: nowrap;
    transition: color var(--t);
    position: relative;
  }
  .nl::after {
    content: '';
    position: absolute; bottom: 4px; left: 14px; right: 14px;
    height: 1px; background: var(--gold);
    transform: scaleX(0); transform-origin: left;
    transition: transform var(--t) var(--ease);
  }
  .nl:hover { color: var(--dark); }
  .nl:hover::after { transform: scaleX(1); }

  .chev { transition: transform 0.25s var(--ease); flex-shrink: 0; }

  /* Dropdown */
  .has-drop { position: relative; }
  .has-drop:hover .chev,
  .has-drop[data-open] .chev { transform: rotate(180deg); }

  .dropdown {
    position: absolute; top: calc(100% + 8px);
    left: 50%; transform: translateX(-50%) translateY(6px);
    min-width: 210px;
    background: var(--ivory);
    border: 1px solid rgba(213,192,57,0.18);
    border-radius: var(--radius);
    list-style: none; padding: 10px 8px;
    opacity: 0; pointer-events: none;
    transition: all 0.22s var(--ease);
    box-shadow: var(--shadow-mid);
  }

  .has-drop:hover .dropdown,
  .has-drop[data-open] .dropdown {
    opacity: 1; pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown li a {
    display: block; padding: 9px 16px;
    font-size: 0.8rem; color: var(--text-soft);
    font-weight: 400; letter-spacing: 0.04em;
    transition: all 0.2s; border-radius: 2px;
  }
  .dropdown li a:hover { color: var(--dark); background: var(--ivory-mid); }

  /* CTA */
  .cta-desktop { flex-shrink: 0; margin-left: 20px; }

  .mobile-cta { display: none; padding: 12px 0; }

  /* Hamburger */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 6px;
    margin-left: 10px;
  }
  .hamburger span {
    display: block; width: 22px; height: 1.5px;
    background: var(--dark); border-radius: 2px;
    transition: all 0.3s var(--ease);
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; width: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

  @media (max-width: 960px) {
    .hamburger { display: flex; }
    .cta-desktop { display: none; }
    .mobile-cta { display: flex; }

    .nav-links {
      position: fixed; top: 72px; left: 0; right: 0;
      background: var(--ivory);
      flex-direction: column; align-items: stretch;
      padding: 16px 20px 28px;
      border-bottom: 1px solid rgba(213,192,57,0.2);
      max-height: calc(100vh - 72px); overflow-y: auto;
      transform: translateY(-8px); opacity: 0;
      pointer-events: none;
      transition: all 0.28s var(--ease);
      box-shadow: var(--shadow-mid);
    }
    .nav-links.open { transform: translateY(0); opacity: 1; pointer-events: all; }

    .nl { padding: 13px 8px; font-size: 0.88rem; justify-content: space-between; }
    .nl::after { display: none; }

    .dropdown {
      position: static; transform: none; opacity: 1;
      pointer-events: none; box-shadow: none;
      background: var(--ivory-mid); border-radius: 2px;
      border: none; margin: 4px 0 8px;
      max-height: 0; overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s;
      padding: 0 8px;
    }
    .has-drop[data-open] .dropdown { pointer-events: all; max-height: 400px; padding: 8px; }
    .dropdown li a { font-size: 0.85rem; padding: 10px 16px; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger?.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    navLinks?.classList.toggle('open', !open);
  });

  document.querySelectorAll<HTMLElement>('.has-drop').forEach(item => {
    item.querySelector<HTMLButtonElement>('.drop-toggle')?.addEventListener('click', () => {
      if (window.innerWidth <= 960) {
        document.querySelectorAll<HTMLElement>('.has-drop[data-open]').forEach(el => {
          if (el !== item) el.removeAttribute('data-open');
        });
        item.toggleAttribute('data-open');
      }
    });
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      navLinks?.classList.remove('open');
    });
  });
</script>
