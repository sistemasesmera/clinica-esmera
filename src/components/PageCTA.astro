---
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = "¿Lista para tu transformación?",
  sub = "Primera consulta gratuita, sin compromiso. Nuestro equipo te asesora y diseña el protocolo ideal para ti.",
} = Astro.props;
---

<section class="pcta">
  <div class="container pcta-inner">
    <div class="pcta-orn">✦</div>
    <h2 class="pcta-h">{heading}</h2>
    <p class="pcta-sub">{sub}</p>
    <a href="/nosotros#contacto" class="btn btn-gold pcta-btn">
      Pide tu cita gratuita
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5"/></svg>
    </a>
    <p class="pcta-note">Sin compromiso · Atención personalizada · Respuesta en 24 h</p>
  </div>
</section>

<style>
  .pcta {
    background: var(--dark);
    padding: 96px 0;
    text-align: center;
    position: relative; overflow: hidden;
  }
  .pcta::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(213,192,57,0.07) 0%, transparent 60%);
    pointer-events: none;
  }
  .pcta-inner { position: relative; z-index: 1; }

  .pcta-orn { color: var(--gold); opacity: 0.4; font-size: 0.9rem; margin-bottom: 20px; letter-spacing: 0.3em; }

  .pcta-h {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 400; color: rgba(255,255,255,0.9);
    margin-bottom: 16px;
  }

  .pcta-sub {
    font-size: 0.95rem; color: rgba(255,255,255,0.45);
    line-height: 1.75; font-weight: 300;
    max-width: 480px; margin: 0 auto 36px;
  }

  .pcta-btn { margin-bottom: 20px; }

  .pcta-note {
    font-size: 0.72rem; color: rgba(255,255,255,0.22);
    letter-spacing: 0.1em; font-weight: 300;
  }
</style>
