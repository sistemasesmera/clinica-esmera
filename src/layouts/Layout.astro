---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Clínica Esmera | Estética y Medicina Estética",
  description = "Centro de estética y medicina estética en Madrid. Tratamientos faciales, corporales, micropigmentación, aparatología avanzada y medicina estética.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --gold: #D5C039;
    --gold-warm: #C8B432;
    --gold-pale: #F2EDB8;
    --gold-tint: #FAFADC;
    --green: #19C771;
    --dark: #2C2C2C;
    --dark-rich: #242424;
    --ivory: #FAF9F5;
    --ivory-mid: #F5F2E9;
    --ivory-deep: #EDE9DC;
    --white: #FFFFFF;
    --stone: #8C8880;
    --stone-light: #B8B4AC;
    --text: #2C2C2C;
    --text-soft: #5A5750;
    --text-muted: #8C8880;

    --font-display: 'Montserrat', sans-serif;
    --font-serif: 'Montserrat', sans-serif;
    --font-body: 'Montserrat', sans-serif;

    --max-w: 1180px;
    --radius: 4px;
    --shadow-soft: 0 2px 20px rgba(44, 44, 44, 0.06);
    --shadow-mid: 0 8px 40px rgba(44, 44, 44, 0.09);
    --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --t: 0.35s;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
  }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: var(--ivory);
    line-height: 1.7;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    font-weight: 300;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    line-height: 1.15;
    font-weight: 300;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Section header pattern ── */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }
  .eyebrow span {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-warm);
  }

  .sec-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 3.5vw, 3rem);
    font-weight: 200;
    color: var(--dark);
    line-height: 1.18;
    margin-bottom: 18px;
    letter-spacing: -0.02em;
  }

  .sec-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--dark);
  }

  .sec-lead {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.85;
    max-width: 520px;
    font-weight: 300;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    transition: all var(--t) var(--ease);
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-solid {
    background: var(--dark);
    color: var(--ivory);
    padding: 15px 36px;
    border-radius: var(--radius);
  }
  .btn-solid:hover {
    background: var(--gold-warm);
    color: var(--dark);
  }

  .btn-gold {
    background: var(--gold);
    color: var(--dark);
    padding: 15px 36px;
    border-radius: var(--radius);
  }
  .btn-gold:hover {
    background: var(--gold-warm);
    box-shadow: 0 6px 24px rgba(213, 192, 57, 0.35);
  }

  .btn-ghost {
    background: transparent;
    color: var(--ivory);
    padding: 14px 34px;
    border-radius: var(--radius);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
  }

  .btn-ghost-dark {
    background: transparent;
    color: var(--dark);
    padding: 14px 34px;
    border-radius: var(--radius);
    border: 1px solid rgba(44,44,44,0.25);
  }
  .btn-ghost-dark:hover {
    background: var(--dark);
    color: var(--ivory);
    border-color: var(--dark);
  }

  /* ── Gold rule ornament ── */
  .gold-rule {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--gold);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
  }
  .gold-rule::before,
  .gold-rule::after {
    content: '';
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
    flex: 1;
  }
</style>
